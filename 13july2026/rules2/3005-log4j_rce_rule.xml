
<group name="pwc_caas,">
    <!-- CVE-2021-44228 Log4j RCE Vulnerability-->
    <!-- 20231221, prevent using R2L and web in if_group, which will match other web log like zscalernss-web which is not traditional web-accesslog -->
    <rule id="300500" level="5">
        <if_group>accesslog</if_group>
        <match>jndi</match>
        <description>CVE-2021-42288 First condition</description>
        <group>attack_stage_Discovery,attack_category_Network_Scanning,</group>
    </rule>

    <rule id="300501" level="12">
        <if_sid>300500</if_sid>
        <match>rmi|ldap|dns</match>
        <description>[CVE-2021-44228] Log4j RCE attempt detected</description>
        <group>attack_stage_Discovery,attack_category_Network_Scanning,</group>
    </rule>

    <rule id="300502" level="12">
        <if_group>accesslog</if_group>
        <regex>\${ctx:|\${sd:|\${map:|127.0.0.1#|localhost#|[::1]#</regex>
        <description>[CVE-2021-44228] Log4j RCE attempt detected (New Signature)</description>
        <group>attack_stage_Discovery,attack_category_Network_Scanning,</group>
    </rule>

    <rule id="300503" level="12">
        <if_group>accesslog</if_group>
        <regex>\${\${::-\${::-\$\${::-j}}}}</regex>
        <description>[CVE-2021-44228] Log4j RCE attempt detected (New Signature)</description>
        <group>attack_stage_Discovery,attack_category_Network_Scanning,</group>
    </rule>

    <rule id="300590" level="0">
        <if_sid>300501,300502,300503</if_sid>
        <match>drop|incomplete|aged-out|server-rst|denied|deny|reject|reset</match>
        <description>Dropped traffic</description>
    </rule>
</group>


<!-- Modify it at your will. -->
<group name="pwc_caas,syslog,sonicwall,firewall,">
	<rule id="113000" level="3">
		<if_sid>4805</if_sid>
		<id>sslvpn</id>
		<action>User login successful</action>
		<description>SonicWall VPN User login successful.</description>
		<group>vpn,vpn_login_success,</group>
		<options>no_counter</options>
	</rule>
	<rule id="113001" level="3">
		<if_sid>4804</if_sid>
		<id>sslvpn</id>
		<action>User login failed</action>
		<description>SonicWall VPN User login failed.</description>
		<group>vpn,vpn_login_failure,</group>
		<options>no_counter</options>
	</rule>
<!--
Mar 16 09:50:22 192.168.98.254 SSLVPN: id=sslvpn sn=C0EAE47425BA time="2022-03-16 09:50:22" vp_time="2022-03-16 01:50:22 UTC" fw=192.168.98.254 pri=5 m=0 c=700 src=142.250.204.132 dst=192.168.98.254 user="apple2.chan" usr="apple2.chan" msg="Current settings exported" type=mgmt agent="curl/7.79.1"
-->
	<rule id="113002" level="12">
		<if_sid>4805</if_sid>
		<id>sslvpn</id>
		<list field="srcip" lookup="not_address_match_key">etc/lists/private-ip</list>
		<field name="msg">Current settings|Scheduled settings</field>
		<description>SonicWall SMA100 allow unauthenticated user to gain read-only access to unauthorized resources (CVE-2019-7481)</description>
	</rule>
	<rule id="113003" level="0">
		<if_sid>113002</if_sid>
		<field name="agent_string">Mozilla/5.0</field>
		<description>[Whitelist] CVE-2019-7481 exclude Mozilla/5.0</description>
	</rule>

	<rule id="100202" level="3">
		<if_sid>4801</if_sid>
		<field name="msg">drop</field>
		<description>Drop action for SonicWall</description>
	</rule>

	<!--Lower down the sonicwall alert level-->
	<rule id="4801" level="5" overwrite="yes">
		<if_sid>4800</if_sid>
		<status>^1</status>
		<description>SonicWall critical message.</description>
		<group>gpg13_3.2,gdpr_IV_35.7.d,</group>
	</rule>

	<!--overwrite the sonicwall alert-->
	<rule id="4802" level="8" overwrite="yes">
		<if_sid>4800</if_sid>
		<status>^2</status>
		<description>SonicWall critical message.</description>
		<group>gpg13_3.2,gdpr_IV_35.7.d,</group>
	</rule>

	<rule id="4811" level="9" overwrite="yes">
		<if_sid>4801</if_sid>
		<id>^30$|^32$</id>
		<description>SonicWall: Firewall authentication failure.</description>
		<group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,gpg13_3.6,gdpr_IV_35.7.d,gdpr_IV_32.2,hipaa_164.312.b,nist_800_53_AU.14,nist_800_53_AC.7,tsc_CC6.1,tsc_CC6.8,tsc_CC7.2,tsc_CC7.3,</group>
	</rule>

	<rule frequency="8" id="4850" ignore="60" level="5" overwrite="yes" timeframe="120">
		<if_matched_sid>4804</if_matched_sid>
		<description>SonicWall: Multiple firewall warning messages.</description>
		<group>service_availability,pci_dss_10.6.1,gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_AU.6,</group>
	</rule>
	<rule frequency="8" id="4851" ignore="60" level="5" overwrite="yes" timeframe="120">
		<if_matched_sid>4803</if_matched_sid>
		<description>SonicWall: Multiple firewall error messages.</description>
		<group>service_availability,pci_dss_10.6.1,gpg13_3.5,gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_AU.6,</group>
	</rule>
</group>

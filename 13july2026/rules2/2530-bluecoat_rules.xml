
<group name="pwc_caas,">
	<rule id="253000" level="3">
		<decoded_as>bluecoat</decoded_as>
		<description>Group of Bluecoat Logs</description>
		<options>no_counter</options>
	</rule>

	<rule id="253001" level="1">
		<if_sid>253000</if_sid>
		<list field="srcip" lookup="address_match_key">etc/lists/private-ip</list>
		<list field="dstip" lookup="not_address_match_key">etc/lists/private-ip</list>
		<field name="s-action">ACCELERATED|ALLOWED|TUNNELED|TCP_AUTH_HIT|TCP_AUTH_MISS|TCP_AUTH_REDIRECT|TCP_CLIENT_REFRESH|TCP_HIT|TCP_MEM_HIT|TCP_MISS|TCP_NC_MISS|TCP_PARTIAL_MISS|TCP_POLICY_REDIRECT|TCP_REFRESH_HIT|TCP_REFRESH_MISS|TCP_RESCAN_HIT|TCP_SPLASHED|TCP_TUNNELED|UDP_HIT|UDP_MISS|UDP_MISS_NOFETCH|UDP_OBJ|TCP_ACCELERATED|TCP_MISS_RST|TCP_NC_MISS_RST|TCP_WEBSOCKET</field>		<description>Local To Remote Bluecoat Logs</description>
        <group>group_by_data.srcip,</group>
		<!-- DEV-4324 -->
	</rule>

</group>

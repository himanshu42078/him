
<group name="pwc_caas,crowdstrike_cef,group_by_data.cef.extensions.dhost,">
	<rule id="235000" level="3">
		<decoded_as>crowdstrike_cef</decoded_as>
		<description>Group of CrowdStrike with CEF format</description>
		<options>no_counter</options>
	</rule>
	<rule id="235001" level="4">
		<if_sid>235000</if_sid>
		<field name="cef.severity">^0$|^1$|^2$</field>
		<description>Low Severity Alert CrowdStrike: $(cef.description) - $(cef.extensions.dhost)</description>
		<group>severity_low,</group>
	</rule>
	<rule id="235002" level="12">
		<if_sid>235000</if_sid>
		<field name="cef.severity">3</field>
		<field name="cef.extensions.msg">\.+</field>
		<description>Medium Severity Alert CrowdStrike: $(cef.description) - $(cef.extensions.dhost)</description>
		<group>severity_medium,</group>
		<!-- DEV-4433 -->
	</rule>
	<rule id="235003" level="12">
		<if_sid>235000</if_sid>
		<field name="cef.severity">4</field>
		<field name="cef.extensions.msg">\.+</field>
		<description>High Severity Alert CrowdStrike: $(cef.description) - $(cef.extensions.dhost)</description>
		<group>severity_high,</group>
		<!-- DEV-4433 -->
	</rule>
	<rule id="235004" level="12">
		<if_sid>235000</if_sid>
		<field name="cef.severity">5</field>
		<field name="cef.extensions.msg">\.+</field>
		<description>Critical Severity Alert CrowdStrike: $(cef.description) - $(cef.extensions.dhost)</description>
		<group>severity_high,</group>
		<!-- DEV-4433 -->
	</rule>


	<rule id="235005" level="0">
		<if_sid>235000,235004</if_sid>
		<field name="cef.event_class_id">IncidentSummaryEvent</field>
		<description>CrowdStrike Alert: $(cef.description) - $(cef.extensions.dhost)</description>
		<group>severity_high,</group>
		<!-- DEV-3495 -->
		<!-- 20231031, there may be no cef.extensions.msg for IncidentSummaryEvent -->
	</rule>	
	<rule id="235006" level="4">
		<if_sid>235005</if_sid>
		<field name="cef.extensions.cn3">^0$|^1$|^2$|E-01$|^1\.*E+00$|^2\.*E+00$</field>
		<description>Low Severity Alert CrowdStrike: $(cef.description) - $(cef.extensions.dhost)</description>
		<group>severity_low,</group>
		<!-- DEV-3495 -->
	</rule>	
	<rule id="235007" level="12">
		<if_sid>235005</if_sid>
		<field name="cef.extensions.cn3">^3$|^4$|^3\.*E+00$|^4\.*E+00$</field>
		<description>Medium Severity Alert CrowdStrike: $(cef.description) - $(cef.extensions.dhost)</description>
		<group>severity_medium,</group>
		<!-- DEV-3495 -->
	</rule>	
	<rule id="235008" level="12">
		<if_sid>235005</if_sid>
		<field name="cef.extensions.cn3">^5$|^6$|^5\.*E+00$|^6\.*E+00$</field>
		<description>High Severity Alert CrowdStrike: $(cef.description) - $(cef.extensions.dhost)</description>
		<group>severity_high,</group>
		<!-- DEV-3495 -->
	</rule>	
	<rule id="235009" level="12">
		<if_sid>235005</if_sid>
		<field name="cef.extensions.cn3">^7$|^8$|^9$|^10$|^7\.*E+00$|^8\.*E+00$|^9\.*E+00$</field>
		<description>Critical Severity Alert CrowdStrike: $(cef.description) - $(cef.extensions.dhost)</description>
		<group>severity_high,</group>
		<!-- DEV-3495 -->
	</rule>		

	<rule id="235010" level="0">
		<if_sid>235000</if_sid>
		<field name="cef.event_class_id">DetectionSummaryEvent</field>
		<field name="cef.extensions.msg">\.+</field>
		<description>CrowdStrike Alert: $(cef.description) - $(cef.extensions.dhost)</description>
		<!-- DEV-3496 -->
	</rule>	
	<rule id="235011" level="4">
		<if_sid>235010</if_sid>
		<field name="cef.severity">^0$|^1$|^2$|20|30</field>
		<description>Low Severity Alert CrowdStrike: $(cef.description) - $(cef.extensions.dhost)</description>
		<group>severity_low,</group>
		<!-- DEV-3496 -->
		<!-- DEV-5833 -->
	</rule>
	<rule id="235012" level="12">
		<if_sid>235010</if_sid>
		<field name="cef.severity">^3$|40|50</field>
		<description>Medium Severity Alert CrowdStrike: $(cef.description) - $(cef.extensions.dhost)</description>
		<group>severity_medium,</group>
		<!-- DEV-3496 -->
		<!-- DEV-5833 -->
	</rule>
	<rule id="235013" level="12">
		<if_sid>235010</if_sid>
		<field name="cef.severity">^4$|60|70</field>
		<description>High Severity Alert CrowdStrike: $(cef.description) - $(cef.extensions.dhost)</description>
		<group>severity_high,</group>
		<!-- DEV-3496 -->
		<!-- DEV-5833 -->
	</rule>
	<rule id="235014" level="12">
		<if_sid>235010</if_sid>
		<field name="cef.severity">^5$|80|90</field>
		<description>Critical Severity Alert CrowdStrike: $(cef.description) - $(cef.extensions.dhost)</description>
		<group>severity_high,</group>
		<!-- DEV-3496 -->
		<!-- DEV-5833 -->
	</rule>	
	<rule id="235015" level="3">
		<if_sid>235010</if_sid>
		<field name="cef.severity">10</field>
		<description>Informational Severity Alert CrowdStrike: $(cef.description) - $(cef.extensions.dhost)</description>
		<group>severity_low,</group>
		<!-- DEV-5833 -->
	</rule>		
</group>

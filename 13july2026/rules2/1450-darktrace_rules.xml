
<group name="pwc_caas,darktrace,">
	<rule id="106600" level="0">
		<decoded_as>darktrace-syslog</decoded_as>
		<description>Group of DarkTrace Syslog</description>
	</rule>
	<rule id="106601" level="3">
		<if_sid>106600</if_sid>
		<field name="severity">0|1|2|3</field>
		<description>DarkTrace Low Alert</description>
		<group>severity_low,</group>
	</rule>
	<rule id="106602" level="5">
		<if_sid>106600</if_sid>
		<field name="severity">4|5|6</field>
		<description>DarkTrace Medium Alert</description>
		<group>severity_medium,</group>
	</rule>
	<rule id="106603" level="12">
		<if_sid>106600</if_sid>
		<field name="severity">7|8|9|1\d</field>
		<description>DarkTrace High Alert</description>
		<group>auto_escalate_disabled,l2_review_required,severity_high,</group>
	</rule>

	<rule id="106604" level="0">
		<decoded_as>darktrace-json</decoded_as>
		<description>Group of DarkTrace JSON</description>
	</rule>
	<rule id="106605" level="12">
		<if_sid>106604</if_sid>
		<field name="model.name">\.+</field>
		<description>DarkTrace Alert - $(model.name)</description>
		<group>auto_escalate_disabled,l2_review_required,group_by_data.system_name,</group>
	</rule>	
	<rule id="106606" level="12">
		<if_sid>106604</if_sid>
		<field name="title">\.+</field>
		<description>DarkTrace Alert - $(title)</description>
		<group>auto_escalate_disabled,l2_review_required,group_by_data.system_name,</group>
	</rule>		
</group>

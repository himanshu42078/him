
<group name="pwc_caas,whispergate,">
	<!-- New rule Possible WhisperGate / DEV-0586 Behaviour Activity Patterns (via cmdline)-->
	<rule id="300700" level="5">
		<if_sid>60103</if_sid>
		<field name="win.system.eventID">^4688$</field>
		<field name="win.eventdata.newProcessName">PerfLogs|ProgramData|temp</field>
		<field name="win.eventdata.newProcessName">stage</field>
        <description>Possible WhisperGate Behaviour Activity Patterns (via cmdline)[1]</description>
        <group>attack_stage_Execution,attack_category_Malware_Detection,</group>
	</rule>
	<!-- this should have many alerts -->

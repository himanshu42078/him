	<rule id="300751" level="5">
		<if_sid>60103</if_sid>
		<field name="win.system.eventID">^4688$</field>
		<field name="win.eventdata.commandLine">rundll32 C:\\windows\\system32\\comsvcs.dll MiniDump|appdata\\local\\microsoft\\windows\\winupd.log|CSIDL_SYSTEM_DRIVE\\temp\\sys.tmp1|\\policydefinitions\\postgresql.exe</field>
		<description>Possible Ukraine-Russia - Disk-wiping Attacks</description>
		<!-- DEV-1342 -->
	</rule>	
        <rule id="300752" level="3">
                <if_sid>60103</if_sid>
                <field name="win.system.eventID">^4688$</field>

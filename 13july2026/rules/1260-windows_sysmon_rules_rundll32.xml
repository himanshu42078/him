<group name="pwc_caas,OS,windows,all_client,sysmon,">
    <!-- sysmon event 1 - Detect dll run by Rundll32 -->
	<rule id="103200" level="12">
		<if_group>sysmon_event1</if_group>
		<field name="sysmon.commandLine">Rundll32.exe\.+.dll</field>
		<description>Detect dll run by Rundll32 - $(sysmon.commandLine)</description>
		<group>attack_stage_Execution,attack_category_Suspicious_Command_Execution,groupid_107200,</group>
	</rule>
	<!-- Windows event 4688 - Detect dll run by Rundll32 -->
	<rule id="103201" level="12">
		<if_sid>18104</if_sid>
		<id>^4688$</id>
		<field name="processCommandLine">Rundll32.exe\.+.dll</field>
		<description>Detect dll run by Rundll32 - $(processCommandLine)</description>
		<group>attack_stage_Execution,attack_category_Suspicious_Command_Execution,</group>
	</rule>

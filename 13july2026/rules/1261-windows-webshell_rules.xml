<group name="pwc_caas,webshell,windows_eventchannel,">
    <!-- DEV-4446 -->
    <!--
    Reference:
    https://github.com/SigmaHQ/sigma/blob/master/rules/windows/process_creation/proc_creation_win_webshell_detection.yml
    -->
	<rule id="126100" level="3">
		<if_sid>60103</if_sid>
		<field name="win.system.eventID">^4688$</field>
		<field name="win.eventdata.parentProcessName">\\w3wp.exe$|\\php.exe$|\\php-cgi.exe$|\\nginx.exe$|\\httpd.exe$|\\caddy.exe$|\\ws_tomcatservice.exe$</field>
		<description>Creation from Webserver Images</description>
	</rule>

   	<rule id="126101" level="3">
		<if_sid>60103</if_sid>
		<field name="win.system.eventID">^4688$</field>
		<field name="win.eventdata.parentProcessName">\\java.exe$|\\javaw.exe$</field>
		<description>Creation from Java</description>
	</rule> 
   	<rule id="126102" level="5">
		<if_sid>126101</if_sid>
		<field name="win.eventdata.parentProcessName">-tomcat-|\\tomcat</field>
		<description>Creation from Webserver Tomcat - 1</description>
	</rule> 
   	<rule id="126103" level="5">
		<if_sid>126101</if_sid>
		<field name="win.eventdata.commandLine">catalina.jar|CATALINA_HOME</field>
		<description>Creation from Webserver Tomcat - 2</description>
	</rule>

    <rule id="126104" level="12">
		<if_sid>126100,126102,126103</if_sid>
        <field name="win.eventdata.newProcessName">net.exe|net1.exe</field>
		<field name="win.eventdata.commandLine"> user | use | group </field>
		<description>Suspicious webshell-related process creation - net utility</description>
        <group>attack_stage_Persistence,attack_category_System_Configuration_Abuse,demo_rules,</group>
	</rule>
    <rule id="126105" level="12">
		<if_sid>126100,126102,126103</if_sid>
        <field name="win.eventdata.newProcessName">ping.exe</field>
		<field name="win.eventdata.commandLine"> -n </field>
		<description>Suspicious webshell-related process creation - ping utility</description>
        <group>attack_stage_Persistence,attack_category_System_Configuration_Abuse,demo_rules,</group>
	</rule>  
     <rule id="126106" level="12">
		<if_sid>126100,126102,126103</if_sid>
		<field name="win.eventdata.commandLine">&cd&echo|cd /d </field>
		<description>Suspicious webshell-related process creation - change directory</description>
        <group>attack_stage_Persistence,attack_category_System_Configuration_Abuse,demo_rules,</group>
	</rule>  
    <rule id="126107" level="12">
		<if_sid>126100,126102,126103</if_sid>
        <field name="win.eventdata.newProcessName">wmic.exe</field>
		<field name="win.eventdata.commandLine"> /node:</field>
		<description>Suspicious webshell-related process creation - wmic utility</description>
        <group>attack_stage_Persistence,attack_category_System_Configuration_Abuse,demo_rules,</group>
	</rule>
    <rule id="126108" level="12">
		<if_sid>126100,126102,126103</if_sid>
        <field name="win.eventdata.newProcessName">whoami.exe|sysinfo.exe|quser.exe|ipconfig.exe|pathping.exe|tracert.exe|netstat.exe|schtasks.exe|VSSADMIN.EXE|wevtutil.exe|tasklist.exe</field>
		<description>Suspicious webshell-related process creation - misc discovery binary</description>
        <group>attack_stage_Persistence,attack_category_System_Configuration_Abuse,demo_rules,</group>
	</rule>  
    <rule id="126109" level="12">
		<if_sid>126100,126102,126103</if_sid>
        <field name="win.eventdata.commandLine">dir \\+\d+.\d+.\d+.\d+| Test-NetConnection </field>
		<description>Suspicious webshell-related process creation - misc discovery commands</description>
        <group>attack_stage_Persistence,attack_category_System_Configuration_Abuse,</group>
	</rule>    


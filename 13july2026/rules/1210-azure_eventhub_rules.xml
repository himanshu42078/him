<group name="azure,pwc_caas,cloud,">
	<rule id="105500" level="3">
		<decoded_as>AzureEventHub</decoded_as>
		<description>Group of AzureEventHub logs</description>
	</rule>
	<!-- Security Center alerts-->
	<rule id="105080" level="13">
		<if_sid>105500</if_sid>
		<field name="eventhub.ProductName">Microsoft Defender for Cloud</field>
		<field name="eventhub.VendorName">Microsoft</field>
		<field name="eventhub.Severity">High</field>
		<description>Microsoft Defender for Cloud High Severity Alerts: $(eventhub.AlertDisplayName)</description>
		<group>groupid_135103,severity_high,</group>
	</rule>
	<rule id="105081" level="13">
		<if_sid>105500</if_sid>
		<field name="eventhub.ProductName">Microsoft Defender for Cloud</field>
		<field name="eventhub.VendorName">Microsoft</field>
		<field name="eventhub.Severity">Medium</field>
		<description>Microsoft Defender for Cloud Medium Severity Alerts: $(eventhub.AlertDisplayName)</description>
		<group>groupid_135102,severity_medium,</group>
	</rule>
	<rule id="105082" level="13">
		<if_sid>105500</if_sid>
		<field name="eventhub.ProductName">Microsoft Defender for Cloud</field>
		<field name="eventhub.VendorName">Microsoft</field>
		<field name="eventhub.Severity">Low</field>
		<description>Microsoft Defender for Cloud Low Severity Alerts: $(eventhub.AlertDisplayName)</description>
		<group>groupid_135101,severity_low,</group>
	</rule>
	<rule id="105083" level="13">
		<if_sid>105500</if_sid>
		<field name="eventhub.ProductName">Microsoft Defender for Cloud</field>
		<field name="eventhub.VendorName">Microsoft</field>
		<field name="eventhub.Severity">Informational</field>
		<description>Microsoft Defender for Cloud Informational Severity Alerts: $(eventhub.AlertDisplayName)</description>
		<group>groupid_135101,severity_low,</group>
	</rule>
	<!-- Risky Signin EventHub -->
	<rule id="105090" level="3">
		<if_sid>105500</if_sid>
		<field name="eventhub.category">SignInLogs</field>
		<description>AAD Signin Logs (Eventhub)</description>
	</rule>
	<!-- New rules for Azure, aligning with other Cloud platforms 20230803 -->
	<rule id="105091" level="3">
		<if_sid>105090</if_sid>
		<field name="eventhub.operationName">Sign-in activity</field>
		<field name="eventhub.properties.result">success</field>
		<description>AAD Successful Login</description>
		<!-- DEV-4870 -->
	</rule>
	<rule id="105092" level="5">
		<if_sid>105090</if_sid>
		<field name="eventhub.operationName">Sign-in activity</field>
		<field name="eventhub.properties.result">failure</field>
		<description>AAD Login Failure</description>
		<!-- DEV-4870 -->
	</rule>
	<rule id="105093" level="5">
		<if_sid>105092</if_sid>
		<field name="eventhub.properties.status.errorCode">50074|50126</field>
		<description>AAD Login Failure: $(eventhub.properties.status.failureReason)</description>
		<!-- DEV-4870 -->
	</rule>
	<rule frequency="3" id="105094" level="5" timeframe="300">
		<if_matched_sid>105093</if_matched_sid>
		<same_user/>
		<description>Azure Same User Login Failed Multiple times: $(dstuser)</description>
		<group>demo_rules,DEV-4870,groupid_135023,</group>
		<!-- DEV-4870 -->
	</rule>
	<rule frequency="4" id="105095" level="5" timeframe="300">
		<if_matched_sid>105093</if_matched_sid>
		<same_source_ip/>
		<description>Azure Possible break-in attempt from IP $(srcip)</description>
		<group>demo_rules,DEV-4870,groupid_135018,</group>
		<!-- DEV-4870 -->
	</rule>
	<rule id="105096" level="13">
		<if_sid>105091</if_sid>
		<list field="srcip" lookup="address_match_key">etc/lists/tor-ip</list>
		<description>Successful Azure Login from Tor-IP</description>
		<group>attack_stage_Initial_Access,attack_category_Unauthorised_/_Unrecognised_Device,groupid_135221,</group>
		<!-- DEV-4870 -->
	</rule>
	<rule id="105097" level="12">
		<if_sid>105091</if_sid>
		<list field="srcip" lookup="address_match_key">etc/lists/malware-ip</list>
		<description>Successful Azure Login from malware-IP</description>
		<group>attack_stage_Initial_Access,attack_category_Unauthorised_/_Unrecognised_Device,</group>
		<!-- DEV-4870 -->
	</rule>
	<rule id="105098" level="5">
		<if_sid>105090,105091,105092</if_sid>
		<field name="eventhub.properties.riskEventTypes">TypeunlikelyTravel|anonymizedIPAddress|maliciousIPAddress|malwareInfectedIPAddress|suspiciousIPAddress|leakedCredentials|investigationsThreatIntelligence|genericadminConfirmedUserCompromised|mcasImpossibleTravel|mcasSuspiciousInboxManipulationRules|investigationsThreatIntelligenceSigninLinked|maliciousIPAddressValidCredentialsBlockedIP</field>
		<description>Azure AD Risk Events</description>
		<group>attack_stage_Initial_Access,attack_category_Unauthorised_/_Unrecognised_Device,</group>
		<!-- DEV-4870 -->
	</rule>
 
	<rule id="105110" level="12">
		<if_sid>105090,105091,105092</if_sid>
		<field name="eventhub.properties.riskLevelDuringSignIn">high</field>
		<description>Azure AD Risky Sign-in: $(eventhub.properties.userPrincipalName)</description>
	</rule>
	<!--Whitelisting-->
	<rule id="105111" level="3">
		<if_sid>105082</if_sid>
		<field name="eventhub.ExtendedProperties.DomainName">yaho0.com</field>
		<description>Whitelist yaho0.com</description>
	</rule>
	<rule id="105112" level="3">
		<if_sid>105082</if_sid>
		<field name="eventhub.ExtendedProperties.DomainName">cdn.czx5eyk0exbhwp43ya.biz</field>
		<description>Whitelist CDN domain</description>
	</rule>
	<!-- Solarigate incident -->
	<rule id="105113" level="10">
		<if_sid>105090,105091,105092</if_sid>
		<field name="eventhub.operationName">Set domain authentication|Set federation settings on domain|Add unverified domain</field>
		<description>Azure AD Solarigate Technique: Addition of new federation trusts</description>
	</rule>
	<rule id="105114" level="5">
		<if_sid>105090,105091,105092</if_sid>
		<field name="eventhub.operationName">Add service principal|Add service principal credentials|Add app role assignment to service principal|Add delegated permission grant|Add application|Certificates and secrets management</field>
		<field name="eventhub.properties.result">Success</field>
		<description>Azure AD Solarigate Technique: Backdoor of application with GraphAPI access to emails</description>
	</rule>
	<rule id="105115" level="3">
		<if_sid>105090,105091,105092</if_sid>
		<field name="eventhub.operationName">Consent to application</field>
		<field name="eventhub.properties.result">Success</field>
		<group>aad_eh_consent_to_application,</group>
		<description>AAD Application Consent to Application events</description>
	</rule>
	<rule id="105116" level="3">
		<if_sid>105090,105091,105092</if_sid>
		<field name="eventhub.operationName">Add service principal credentials|Update application - Certificates and secrets management</field>
		<field name="eventhub.properties.result">Success</field>
		<group>aad_eh_add_sp_credentials,</group>
		<description>Added credentials to Azure AD Application</description>
	</rule>
	<rule frequency="2" id="105117" level="10" timeframe="60">
		<if_group>aad_eh_consent_to_application</if_group>
		<if_matched_group>aad_eh_add_sp_credentials</if_matched_group>
		<same_field>eventhub.aad.targetResources.servicePrincipal.id</same_field>
		<description>Azure AD Solarigate Technique: Added credentials to Azure AD Application after Admin Consent permissions granted</description>
	</rule>
	<!-- New audit rules-->
	<rule id="105130" level="3">
		<if_sid>105500</if_sid>
		<field name="eventhub.category">AuditLogs</field>
		<description>AAD Audit Logs (Eventhub)</description>
	</rule>
	<rule id="105131" level="5">
		<if_sid>105130</if_sid>
		<field name="eventhub.operationName">Add User</field>
		<description>AAD: New user added</description>
		<group>groupid_135015,</group>
	</rule>
	<rule id="105132" level="12">
		<if_sid>105131</if_sid>
		<field name="eventhub.properties.result">failure</field>
		<description>AAD: Unsuccessful user creation due to permissions denied</description>
		<group>attack_stage_Persistence,groupid_135016,</group>
	</rule>
	<rule id="105133" level="0">
		<if_sid>105132</if_sid>
		<field name="eventhub.properties.resultReason">Microsoft.Online.DirectoryServices.DirectoryUniquenessException</field>
		<description>Whitelist for AAD user add failure</description>
	</rule>
	<!-- New rules for Azure, aligning with other Cloud platforms-->
	<rule id="105200" level="5">
		<if_sid>105500</if_sid>
		<field name="eventhub.operationName">Microsoft.Compute/virtualMachines/start/action</field>
		<description>Azure: Run a new virtual machine without permission</description>
		<group>attack_stage_Defense_Evasion,</group>
	</rule>
	<rule id="105201" level="1">
		<if_sid>105200</if_sid>
		<field name="eventhub.resultType">Success|Accept|Start</field>
		<description>Azure: Run a new virtual machine successfully (Not an alert)</description>
	</rule>
	<rule id="105202" level="5">
		<if_sid>105500</if_sid>
		<field name="eventhub.operationName">Microsoft.Compute/virtualMachines/powerOff/action</field>
		<field name="eventhub.resultType">Success</field>
		<description>Azure: Stopped a virtual machine</description>
		<group>attack_stage_Defense_Evasion,</group>
	</rule>
	<rule id="105203" level="12">
		<if_sid>105500</if_sid>
		<field name="eventhub.operationName">Microsoft.Network/networkSecurityGroups/delete</field>
		<field name="eventhub.resultType">Success</field>
		<description>Azure: Security Group deleted</description>
		<group>attack_stage_Defense_Evasion,groupid_135004,</group>
	</rule>
	<rule id="105204" level="5">
		<if_sid>105500</if_sid>
		<field name="eventhub.operationName">Microsoft.Network/publicIPAddresses/join/action</field>
		<field name="eventhub.resultType">Success</field>
		<description>Azure: Associate a new Public IP address</description>
		<group>attack_stage_Defense_Evasion,groupid_135011,</group>
	</rule>		
	<rule id="105205" level="5">
		<if_sid>105500</if_sid>
		<field name="eventhub.operationName">Microsoft.Network/virtualNetworkGateways/delete|Microsoft.ClassicNetwork/virtualNetworks/gateways/delete</field>
		<field name="eventhub.resultType">Success</field>
		<description>Azure: Network Gateway being deleted</description>
		<group>attack_stage_Defense_Evasion,</group>
	</rule>
	<rule id="105206" level="5">
		<if_sid>105500</if_sid>
		<field name="eventhub.operationName">Microsoft.Network/publicIPAddresses/write</field>
		<field name="eventhub.resultType">Success</field>
		<description>Azure: Allocate a new Elastic IP address</description>
		<group>attack_stage_Exfiltration,groupid_135010,</group>
	</rule>
	<rule id="105207" level="12">
		<if_sid>105500</if_sid>
		<field name="eventhub.operationName">Microsoft.Network/networkSecurityGroups/securityRules/write</field>
		<field name="eventhub.resultType">Success</field>
		<description>Azure: A rule has been added to a security group</description>
		<group>attack_stage_Exfiltration,</group>
	</rule>
	<rule id="105208" level="12">
		<if_sid>105500</if_sid>
		<field name="eventhub.operationName">Microsoft.Network/networkSecurityGroups/securityRules/delete</field>
		<field name="eventhub.resultType">Success</field>
		<description>Azure: A rule has been removed from a security group</description>
		<group>attack_stage_Exfiltration,</group>
	</rule>
	<rule id="105209" level="12">
		<if_sid>105500</if_sid>
		<field name="eventhub.operationName">Microsoft.Network/networkSecurityGroups/join/action</field>
		<field name="eventhub.resultType">Success</field>
		<description>Azure: Associate a network security group to a subnet or network interface</description>
		<group>attack_stage_Exfiltration,</group>
	</rule>		
	<!-- Legit On-prem directory service account-->
	<rule id="105210" level="5">
		<if_sid>105090,105091,105092</if_sid>
		<field name="eventhub.dstuser">On-Premises Directory Synchronization Service Account</field>
		<field name="eventhub.resultType">0</field>
		<description>Azure: Abnormal Login IP for On-Prem Service account (Pass-thru-authentication backdoor)</description>
		<group>attack_stage_Exfiltration,</group>
	</rule>

	<rule id="105211" level="10">
		<if_sid>105130</if_sid>
		<field name="eventhub.properties.category">^RoleManagement$</field>
		<field name="eventhub.properties.loggedByService">^Core Directory$</field>
		<field name="eventhub.operationName">^Add member to role$|^Add member to role in PIM requested \(permanent\)$</field>
		<match>UserAccountAdmins|PrivilegedRoleAdmins|TenantAdmins|Application Administrator|Authentication Administrator|Cloud Application Administrator|Directory Synchronization Accounts|Directory Writers|Exchange Administrator|Global Administrator|Helpdesk Administrator|Password Administrator|Privileged Authentication Administrator|SharePoint Administrator|User Administrator</match>
		<description>AAD New Administrative Role Assigned to member (Active Assignment)</description>
		<!-- DEV-4872 -->
	</rule>
	<rule id="105212" level="10">
		<if_sid>105130</if_sid>
		<field name="eventhub.properties.category">^RoleManagement$</field>
		<field name="eventhub.properties.loggedByService">^Core Directory$</field>
		<field name="eventhub.operationName">^Add eligible member to role$|^Add eligible member to role in PIM completed \(permanent\)$</field>
		<match>UserAccountAdmins|PrivilegedRoleAdmins|TenantAdmins|Application Administrator|Authentication Administrator|Cloud Application Administrator|Directory Synchronization Accounts|Directory Writers|Exchange Administrator|Global Administrator|Helpdesk Administrator|Password Administrator|Privileged Authentication Administrator|SharePoint Administrator|User Administrator</match>
		<description>AAD New Administrative Role Assigned to member (Eligible Assignment)</description>
		<!-- DEV-4872 -->
	</rule>

	<rule id="105213" level="5">
		<if_sid>105130</if_sid>
		<field name="eventhub.properties.category">^RoleManagement$</field>
		<field name="eventhub.properties.loggedByService">^Core Directory$</field>
		<field name="eventhub.operationName">^Remove member from role$|^Remove member from role in PIM requested \(permanent\)$</field>
		<match>UserAccountAdmins|PrivilegedRoleAdmins|TenantAdmins|Application Administrator|Authentication Administrator|Cloud Application Administrator|Directory Synchronization Accounts|Directory Writers|Exchange Administrator|Global Administrator|Helpdesk Administrator|Password Administrator|Privileged Authentication Administrator|SharePoint Administrator|User Administrator</match>
		<description>AAD Remove Administrative Role from member (Active Assignment)</description>
		<!-- DEV-4872 -->
	</rule>
	<rule id="105214" level="5">
		<if_sid>105130</if_sid>
		<field name="eventhub.properties.category">^RoleManagement$</field>
		<field name="eventhub.properties.loggedByService">^Core Directory$</field>
		<field name="eventhub.operationName">^Remove eligible member from role$|^Remove eligible member from role in PIM completed \(permanent\)$</field>
		<match>UserAccountAdmins|PrivilegedRoleAdmins|TenantAdmins|Application Administrator|Authentication Administrator|Cloud Application Administrator|Directory Synchronization Accounts|Directory Writers|Exchange Administrator|Global Administrator|Helpdesk Administrator|Password Administrator|Privileged Authentication Administrator|SharePoint Administrator|User Administrator</match>
		<description>AAD Remove Administrative Role from member (Eligible Assignment)</description>
		<!-- DEV-4872 -->
	</rule>

	<rule id="105217" level="3">
		<if_sid>105130</if_sid>
		<field name="eventhub.properties.category">^UserManagement$</field>
		<field name="eventhub.operationName">Self-service password reset|Reset password|Reset user password</field>
		<description>Azure Reset password</description>
		<!-- DEV-4872 -->
	</rule>
	<rule id="105218" level="5">
		<if_sid>105217</if_sid>
		<field name="eventhub.properties.result">failure</field>
		<description>Azure Reset password failure</description>
		<!-- DEV-4872 -->
	</rule>
	<rule id="105219" level="3">
		<if_sid>105217</if_sid>
		<field name="eventhub.properties.result">success</field>
		<field name="eventhub.properties.resultReason">Successfully completed reset|User successfully reset password</field>
		<description>Azure Reset password success</description>
		<!-- DEV-4872 -->
	</rule>

	<rule id="105220" level="12">
		<if_sid>105218</if_sid>
		<field name="eventhub.operationName">Blocked from self-service password reset</field>
		<field name="eventhub.properties.resultReason">User throttle for attempting challenge: SecurityQuestions too many times</field>
		<description>Azure Reset password failure: $(eventhub.operationName)</description>
		<!-- DEV-4872 -->
	</rule>

	<rule id="105221" level="13">
		<if_sid>105500</if_sid>
		<field name="eventhub.ProductName">Microsoft Defender ATP</field>
		<field name="eventhub.Severity">High</field>
		<description>Microsoft Defender ATP High Severity Alerts: $(eventhub.AlertDisplayName)</description>
		<group>severity_high,</group>
		<!-- DEV-5735 -->
	</rule>
	<rule id="105222" level="13">
		<if_sid>105500</if_sid>
		<field name="eventhub.ProductName">Microsoft Defender ATP</field>
		<field name="eventhub.Severity">Medium</field>
		<description>Microsoft Defender ATP Medium Severity Alerts: $(eventhub.AlertDisplayName)</description>
		<group>severity_medium,</group>
		<!-- DEV-5735 -->
	</rule>
	<rule id="105223" level="13">
		<if_sid>105500</if_sid>
		<field name="eventhub.ProductName">Microsoft Defender ATP</field>
		<field name="eventhub.Severity">Low</field>
		<description>Microsoft Defender ATP Low Severity Alerts: $(eventhub.AlertDisplayName)</description>
		<group>severity_low,</group>
		<!-- DEV-5735 -->
	</rule>
	<rule id="105224" level="13">
		<if_sid>105500</if_sid>
		<field name="eventhub.ProductName">Microsoft Defender ATP</field>
		<field name="eventhub.Severity">Informational</field>
		<description>Microsoft Defender ATP Informational Severity Alerts: $(eventhub.AlertDisplayName)</description>
		<group>severity_low,</group>
		<!-- DEV-5735 -->
	</rule>

	<rule id="105225" level="13">
		<if_sid>105500</if_sid>
		<field name="eventhub.category">AZFWThreatIntel</field>
		<description>Reported IP Detected by Azure Threat Intelligence</description>
		<group>attack_stage_Initial_Access,</group>
		<!-- DEV-5708 -->
	</rule>

	<rule id="105226" level="13">
		<if_sid>105500</if_sid>
		<field name="eventhub.category">AppServiceAntivirusScanLogs</field>
		<field name="eventhub.NumberOfInfectedFiles" negate="yes">-1</field>
		<description>Infected Files Detected by Azure Threat Intelligence</description>
		<group>attack_stage_Execution,attack_category_Malware_Detection,demo_rules,</group>
		<!-- DEV-5708 -->
	</rule>

</group>

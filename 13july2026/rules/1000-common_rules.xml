<group name="network_traffic,">
	<rule id="100050" level="1">
		<if_sid>106250,64220,4700,14200,82400,64000,9700,20100,20101,82000,5100,12100,80100,4500,51500,2507,4300,81900,80500,20102,6100,4806,87700,81603,4100,137500,138500,143000,146000,278002</if_sid>
		<description>Network Device</description>
	</rule>
	<!-- Local to Local -->
	<rule id="100051" level="1">
		<if_sid>100050</if_sid>
		<list field="srcip" lookup="address_match_key">etc/lists/private-ip</list>
		<list field="dstip" lookup="address_match_key">etc/lists/private-ip</list>
		<description>Local to Local</description>
		<group>L2L,</group>
	</rule>
	<!-- Local to Remote -->
	<rule id="100052" level="1">
		<if_sid>100050</if_sid>
		<list field="srcip" lookup="address_match_key">etc/lists/private-ip</list>
		<list field="dstip" lookup="not_address_match_key">etc/lists/private-ip</list>
		<description>Local to Remote</description>
		<group>L2R,</group>
	</rule>
	<!-- Remote to Local -->
	<rule id="100053" level="1">
		<if_sid>100050</if_sid>
		<list field="srcip" lookup="not_address_match_key">etc/lists/private-ip</list>
		<list field="dstip" lookup="address_match_key">etc/lists/private-ip</list>
		<description>Remote to Local</description>
		<group>R2L,</group>
	</rule>
	<!-- Remote to Remote -->
	<rule id="100054" level="1">
		<if_sid>100050</if_sid>
		<list field="srcip" lookup="not_address_match_key">etc/lists/private-ip</list>
		<list field="dstip" lookup="not_address_match_key">etc/lists/private-ip</list>
		<description>Remote to Remote</description>
		<group>R2R,</group>
	</rule>
	<!-- Secondary check for Internal IPs-->
	<rule id="100055" level="0">
		<if_sid>100052,100054</if_sid>
		<dstip>10.0.0.0/8</dstip>
		<description>External DstIP</description>
	</rule>
	<rule id="100056" level="0">
		<if_sid>100052,100054</if_sid>
		<dstip>172.16.0.0/12</dstip>
		<description>External DstIP</description>
	</rule>
	<rule id="100057" level="0">
		<if_sid>100052,100054</if_sid>
		<dstip>192.168.0.0/16</dstip>
		<description>External DstIP</description>
	</rule>
	<rule id="100058" level="0">
		<if_sid>100052,100054</if_sid>
		<dstip>169.254.0.0/16</dstip>
		<description>External DstIP</description>
	</rule>
	<rule id="100059" level="0">
		<if_sid>100052,100054</if_sid>
		<dstip>100.64.0.0/10</dstip>
		<description>External DstIP</description>
	</rule>
	<rule id="100060" level="0">
		<if_sid>100053,100054</if_sid>
		<srcip>10.0.0.0/8</srcip>
		<description>External DstIP</description>
	</rule>
	<rule id="100061" level="0">
		<if_sid>100053,100054</if_sid>
		<srcip>172.16.0.0/12</srcip>
		<description>External DstIP</description>
	</rule>
	<rule id="100062" level="0">
		<if_sid>100053,100054</if_sid>
		<srcip>192.168.0.0/16</srcip>
		<description>External DstIP</description>
	</rule>
	<rule id="100063" level="0">
		<if_sid>100053,100054</if_sid>
		<srcip>169.254.0.0/16</srcip>
		<description>External DstIP</description>
	</rule>
	<rule id="100064" level="0">
		<if_sid>100053,100054</if_sid>
		<srcip>100.64.0.0/10</srcip>
		<description>External DstIP</description>
	</rule>
</group>

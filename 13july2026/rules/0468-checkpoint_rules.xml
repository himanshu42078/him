
<group name="pwc_caas,checkpoint-syslog,">
	<rule id="138500" level="2">
		<decoded_as>checkpoint_cef</decoded_as>
		<description>Group of Checkpoint(Syslog) logs</description>
	</rule>
	<rule id="138501" level="4">
		<if_sid>138500</if_sid>
		<field name="cef.extensions.product_family">Endpoint</field>
		<description>Group of Checkpoint Endpoint logs</description>
	</rule>
	<rule id="138502" level="0">
		<if_sid>138500</if_sid>
		<field name="cef.event_class_id">Log</field>

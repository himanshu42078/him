		<!-- DEV-4704 -->
	</rule>	
	<rule id="138507" level="12">
		<if_sid>138501</if_sid>
		<field name="cef.extensions.cp_severity">^Low$</field>
		<description>Checkpoint $(cef.extensions.product) Low Severity Alert.</description>
		<group>severity_low,</group>
	</rule>

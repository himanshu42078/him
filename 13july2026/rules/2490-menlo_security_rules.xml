
<group name="pwc_caas,menlo_security,">
    <rule id="249000" level="0">
        <decoded_as>menlo-json</decoded_as>
        <description>Group of Menlo Logs</description>
        <options>no_counter</options>
        <group>L2R,</group>
    </rule>

    <rule id="249001" level="12">
        <if_sid>249000</if_sid>

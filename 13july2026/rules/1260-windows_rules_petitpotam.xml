
<!-- Modify it at your will. -->
<!-- https://caas.pwchk.com/browse/DEV-854 -->
<group name="pwc_caas,windows,windows_eventchannel,">
    <!-- REF: https://docs.microsoft.com/en-us/windows/security/threat-protection/auditing/event-4624 -->
	<rule id="209001" level="3">
		<if_sid>60103</if_sid>
		<field name="win.system.eventID">^4624$</field>
		<field name="win.eventdata.targetUserName">^ANONYMOUS LOGON$</field>
		<field name="win.eventdata.authenticationPackageName">NTLM</field>
		<description>Anonymous Bind to RPC during PetitPatam, as well as any Anonymous connections.</description>
	</rule>
	<rule id="209002" level="3">
		<if_sid>60103</if_sid>
		<field name="win.system.eventID">^4624$</field>
		<!-- Elevated Token:%%1842 is the same as elevated=true -->
		<field name="win.eventdata.elevatedToken">^%%1842$</field>
		<field name="win.eventdata.lmPackageName">^NTLM V2$</field>
		<description>Elevated User Access without Source Workstation.</description>
	</rule>
	<rule id="209012" level="0">
		<if_sid>209002</if_sid>
		<field name="win.eventdata.workstationName">\.+</field>
		<description>Whitelist Elevated User Access with Source Workstation.</description>
	</rule>
    <!-- REF: https://docs.microsoft.com/en-us/windows/security/threat-protection/auditing/event-5145 -->
	<rule id="209003" level="12">
		<if_sid>60103</if_sid>
		<field name="win.system.eventID">^5145$</field>
		<field name="win.eventdata.shareName">\.*IPC\.*</field>
		<field name="win.eventdata.shareLocalPath">lsarpc|efsrpc|lsass|samr|netlogon</field>
		<field name="win.eventdata.accessList">\.*%%4416\.*</field>
        <field name="win.eventdata.accessList">\.*%%4417\.*</field>
		<description>Detailed File Share Access with a Specific Set of Accesses and Sources</description>
	</rule>
	<rule id="209004" level="12">
		<if_sid>60103</if_sid>
		<field name="win.eventdata.targetUserName">DC\.*\$$|AD\.*\$$|NS\.*\$$</field>
		<field name="win.system.eventID">^4768$</field>
		<field name="win.eventdata.certSerialNumber">\.*1\.*|\.*2\.*|\.*4\.*|\.*6\.*|\.*8\.*|\.*0\.*</field>
		<description>PetitPotam Suspicious Kerberos TGT Request.</description>
		<group>auto_escalate_disabled,</group>
		<!-- DEV-3256 -->
	</rule>
	<rule id="209005" level="12">
		<if_sid>60103</if_sid>
		<field name="win.eventdata.targetUserName">DC\.*\$$|AD\.*\$$|NS\.*\$$</field>
		<field name="win.system.eventID">^4768$</field>
		<field name="win.eventdata.certThumbprint">\.*1\.*|\.*3\.*|\.*4\.*|\.*6\.*|\.*8\.*|\.*0\.*|\.*CN\.*</field>
		<description>PetitPotam Suspicious Kerberos Certification Thumbprint</description>
		<group>auto_escalate_disabled,</group>
	</rule>
</group>

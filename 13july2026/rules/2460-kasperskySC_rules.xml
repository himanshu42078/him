
<group name="pwc_caas,kasperskySC_cef,antivirus,">
	<rule id="246000" level="3">
		<decoded_as>kasperskylab_cef</decoded_as>
		<description>Group of kasperskySC CEFs</description>
		<options>no_counter</options>
	</rule>
	<rule id="246001" level="12">
		<if_sid>246000</if_sid>
		<field name="cef.event_class_id">GNRL_EV_SUSPICIOUS_OBJECT_FOUND</field>
		<description>KasperskySC alert: Suspicious object found.</description>
	</rule>
	<rule id="246002" level="5">
		<if_sid>246000</if_sid>
		<field name="cef.event_class_id">GNRL_EV_VIRUS_FOUND</field>
		<description>KasperskySC alert: Virus found.</description>
        <group>group_by_data.cef.extensions.MD5,</group>
	</rule>
	<rule id="246003" level="12">
		<if_sid>246000</if_sid>
		<field name="cef.event_class_id">GNRL_EV_PASSWD_ARCHIVE_FOUND</field>
		<description>KasperskySC alert: Password-protected archive was found.</description>
	</rule>
	<rule id="246004" level="12">
		<if_sid>246000</if_sid>
		<field name="cef.event_class_id">GNRL_EV_OBJECT_NOTCURED</field>
		<description>KasperskySC alert: object was not cured.</description>
	</rule>
	<rule id="246005" level="12">
		<if_sid>246000</if_sid>
		<field name="cef.event_class_id">GNRL_EV_OBJECT_DELETED</field>
		<description>KasperskySC alert: object was deleted.</description>
        <group>group_by_data.cef.extensions.MD5,</group>
	</rule>
	<rule id="246006" level="5">
		<if_sid>246000</if_sid>
		<field name="cef.event_class_id">GNRL_EV_OBJECT_BLOCKED</field>
		<description>KasperskySC alert: object was blocked.</description>
        <group>group_by_data.cef.extensions.MD5,</group>
	</rule>	  	
</group>

	<!-- The decoder name is updated in Jan 2021, new decoder name is called AzureGraphAPI-json. The original one was just 'json'-->
	<group name="azure,pwc_caas,cloud,">
		<rule id="87801" level="3">
			<decoded_as>AzureGraphAPI-json</decoded_as>
			<field name="azure.azure_tag">azure-log-analytics</field>
			<description>Azure: Log analytics</description>
		</rule>
		<rule id="87802" level="3">
			<decoded_as>AzureGraphAPI-json</decoded_as>
			<field name="azure.azure_tag">azure-ad-graph</field>
			<description>Azure: AD $(activity)</description>
		</rule>
		<rule id="87803" level="3">
			<decoded_as>AzureGraphAPI-json</decoded_as>
			<field name="azure.azure_tag">azure-storage</field>
			<description>Azure: Storage</description>
		</rule>
		<rule id="87804" level="3">
			<decoded_as>azure-storage</decoded_as>
			<description>Azure: Storage</description>
		</rule>
		<rule id="87810" level="3">
			<if_sid>87801</if_sid>
			<field name="azure.Type">AzureActivity</field>
			<description>Azure: Log analytics activity</description>
		</rule>
		<rule id="87811" level="3">
			<if_sid>87810</if_sid>
			<field name="azure.operationName">\.+</field>
			<description>Azure: Log analytics: $(azure.operationName)</description>
		</rule>
		<rule id="87813" level="3">
			<if_sid>87803</if_sid>
			<field name="azure.operationName">\.+</field>
			<description>Azure: Storage: $(azure.operationName)</description>
		</rule>
		<rule id="87850" level="3">
			<if_sid>87802</if_sid>
			<field name="azure.azure_aad_tag">signin</field>
			<description>AAD Signin Logs (Graph API)</description>
		</rule>
		<rule id="87851" level="3">
			<if_sid>87802</if_sid>
			<field name="azure.azure_aad_tag">audit</field>
			<description>AAD Audit Logs (Graph API)</description>
		</rule>

		<rule id="87852" level="3">
			<if_sid>87850</if_sid>
			<field name="azure.conditionalAccessStatus">success</field>
			<description>Azure Successful Login</description>
			<!-- DEV-4868 -->
		</rule>
		<rule id="87853" level="5">
			<if_sid>87850</if_sid>
			<field name="azure.conditionalAccessStatus">failure|notApplied</field>
			<field name="azure.status.errorCode">50126</field>
			<field name="azure.status.failureReason">Error validating credentials due to invalid username or password</field>
			<description>Azure Login Failure: $(azure.status.failureReason)</description>
			<!-- DEV-4868 -->
		</rule>
		<rule frequency="10" id="87854" level="10" timeframe="120">
			<if_matched_sid>87853</if_matched_sid>
			<same_user/>
			<description>Azure/O365 Same User Login Failed Multiple times: $(dstuser)</description>
			<group>demo_rules,group_by_data.dstuser,DEV-4868,groupid_135023,</group>
			<!-- DEV-4868 -->
		</rule>
		<rule frequency="10" id="87855" level="10" timeframe="120">
			<if_matched_sid>87853</if_matched_sid>
			<same_source_ip/>
			<description>Azure/O365 Possible break-in attempt from IP $(srcip)</description>
			<group>group_by_data.srcip,groupid_135018,</group>
			<!-- DEV-4868 -->
		</rule>
		<!-- DEV-4868 combine with 104056,104057
		<rule id="87856" level="13">
			<if_sid>87852</if_sid>
			<list field="srcip" lookup="address_match_key">etc/lists/tor-ip</list>
			<description>Successful Azure Login from Tor-IP</description>
			<group>attack_stage_Initial_Access,attack_category_Unauthorised_/_Unrecognised_Device,</group>
		</rule>
		<rule id="87857" level="12">
			<if_sid>87852</if_sid>
			<list field="srcip" lookup="address_match_key">etc/lists/malware-ip</list>
			<description>Successful Azure Login from malware-IP</description>
			<group>attack_stage_Initial_Access,attack_category_Unauthorised_/_Unrecognised_Device,group_by_data.srcip,</group>
		</rule>
		-->
		<rule id="87858" level="10">
			<if_sid>87850</if_sid>
			<field name="azure.riskEventTypes">TypeunlikelyTravel|maliciousIPAddress|malwareInfectedIPAddress|suspiciousIPAddress|leakedCredentials|investigationsThreatIntelligence|genericadminConfirmedUserCompromised|mcasImpossibleTravel|mcasSuspiciousInboxManipulationRules|investigationsThreatIntelligenceSigninLinked|maliciousIPAddressValidCredentialsBlockedIP</field>
			<description>Azure AD Risk Events: $(azure.status.failureReason)</description>
			<group>attack_stage_Initial_Access,attack_category_Unauthorised_/_Unrecognised_Device,</group>
			<!-- DEV-4868 -->
		</rule>
		
		<rule id="87860" level="12">
			<if_sid>87850,87852,87853</if_sid>
			<field name="azure.riskLevelDuringSignIn">high</field>
            <field name="azure.location.countryOrRegion">NG|BG|BJ</field> <!-- DEV-1083 -->
			<description>Azure AD Risky Sign-in: $(azure.userDisplayName)</description>
			<group>groupid_135203,</group>
		</rule>
				<rule id="87861" level="0">
			<if_sid>87860</if_sid>
			<field name="azure.status.errorCode">50140</field>
			<description>Excluding Error Code 50140 for High AAD Risky Sign-in</description>
		</rule>
		<!-- Solarigate incident -->
		<rule id="87870" level="10">
			<if_sid>87851</if_sid>
			<field name="azure.activityDisplayName">Set domain authentication|Set federation settings on domain|Add unverified domain</field>
			<description>Azure AD Solarigate Technique: Addition of new federation trusts</description>
		</rule>
		<rule id="87871" level="5">
			<if_sid>87851</if_sid>
			<field name="azure.activityDisplayName">Add service principal|Add service principal credentials|Add app role assignment to service principal|Add delegated permission grant|Add application|Certificates and secrets management</field>
			<field name="azure.result">Success</field>
			<description>Azure AD Solarigate Technique: Backdoor of application with GraphAPI access to emails</description>
		</rule>
		<rule id="87872" level="3">
			<if_sid>87851</if_sid>
			<field name="azure.activityDisplayName">Consent to application</field>
			<field name="azure.result">Success</field>
			<group>aad_consent_to_application</group>
			<description>AAD Application Consent to Application events</description>
		</rule>
		<rule id="87873" level="3">
			<if_sid>87851</if_sid>
			<field name="azure.activityDisplayName">Add service principal credentials|Update application - Certificates and secrets management</field>			<field name="azure.result">Success</field>
			<group>aad_add_sp_credentials</group>
			<description>Added credentials to Azure AD Application</description>
		</rule>
		<rule frequency="2" id="87874" level="5" timeframe="60">
			<if_group>aad_consent_to_application</if_group>
			<if_matched_group>aad_add_sp_credentials</if_matched_group>
			<same_field>azure.targetResources.servicePrincipal.id</same_field>
			<description>Azure AD Solarigate Technique: Added credentials to Azure AD Application after Admin Consent permissions granted</description>
		</rule>
		<rule id="87875" level="4">
			<if_sid>87851</if_sid>
			<field name="azure.category">UserManagement</field>
			<field name="azure.activityDisplayName">Add user</field>
			<description>AAD New User Created</description>
			<group>groupid_135015,</group>
		</rule>
		<rule id="87876" level="12">
			<if_sid>87875</if_sid>
			<field name="azure.result">failure</field>
			<description>AAD Unsuccessful user creation due to permissions denied</description>
			<group>groupid_135016,</group>
		</rule>


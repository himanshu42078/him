			<!-- DEV-4871 -->
		</rule>
		<rule id="87888" level="5">
			<if_sid>87887</if_sid>
			<field name="azure.result">failure</field>
			<description>Azure Reset password failure</description>
			<!-- DEV-4871 -->
		</rule>
		<rule id="87889" level="3">
			<if_sid>87887</if_sid>
			<field name="azure.result">success</field>
			<field name="azure.resultReason">Successfully completed reset|User successfully reset password</field>
			<description>Azure Reset password success</description>
			<!-- DEV-4871 -->
		</rule>
		
		<!-- 87850 Signin Graph API-->

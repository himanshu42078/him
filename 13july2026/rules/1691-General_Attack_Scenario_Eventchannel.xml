	<!-- Source: Sentinel HAFNIUMUmServiceSuspiciousFile.yaml -->
	<rule id="120300" level="12">
		<if_sid>60103</if_sid>
		<field name="win.system.eventID">^4663$</field>
		<field name="win.eventdata.objectName">.php$|.jsp$|.js$|.aspx$|.asmx$|.asax$|.cfm$|.shtml$</field>
		<field name="win.eventdata.newProcessName">umworkerprocess|UMService</field>
		<field name="win.eventdata.accessMask">0x2|0x100|0x10|0x4</field>
		<description>Exchange Zero Day Vulnerability - HAFNIUM UM Service writing suspicious file</description>
		<group>attack_stage_Initial_Access,attack_category_Exploit_Public-Facing_Application,</group>
	</rule>
	<!-- Source: HAFNIUM Suspicious UM Service Error-->
	<rule id="120301" level="12">
		<if_sid>60602</if_sid>
		<field name="win.system.providerName">^MSExchange</field>
		<field name="win.system.message">^Watson report</field>
		<field name="win.system.message">umworkerprocess</field>
		<field name="win.system.message">TextFormattingRunProperties</field>
		<description>Exchange Zero Day Vulnerability - HAFNIUM Suspicious UM Service Error (1)</description>
		<group>attack_stage_Initial_Access,attack_category_Exploit_Public-Facing_Application,</group>
	</rule>
	<rule id="120302" level="12">
		<if_sid>60602</if_sid>
		<field name="win.system.providerName">^MSExchange</field>
		<field name="win.system.message">^An unhandled exception occurred in a UM worker process|^The Microsoft Exchange Unified Messaging service</field>
		<description>Exchange Zero Day Vulnerability - HAFNIUM Suspicious UM Service Error (2)</description>
		<group>attack_stage_Initial_Access,attack_category_Exploit_Public-Facing_Application,</group>
	</rule>
	<rule id="120303" level="0">
		<if_sid>120301,120302</if_sid>
		<field name="win.system.message">System.OutOfMemoryException</field>
		<description>Whitelist HAFNIUM UM Service Error Exception</description>
	</rule>

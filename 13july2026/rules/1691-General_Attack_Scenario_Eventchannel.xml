<group name="pwc_caas,General_Attack_Scenario_Eventchannel,">
	<!--Detection for Kerberoasting is not effective. Enable with caution.-->
	<rule id="120000" level="5">
		<if_sid>60106</if_sid>
		<field name="win.system.eventID">^4769$</field>
		<field name="win.eventdata.ticketEncryptionType">0x17</field>
		<field name="win.eventdata.status">0x0</field>
		<description>Detected Potential Kerberoasting Attack</description>
		<group>attack_stage_Credential_Access,attack_category_Credentials_Dumping,</group>
	</rule>
	<rule id="120001" level="0">
		<if_sid>120000</if_sid>
		<field name="win.eventdata.serviceName">krbtgt</field>
		<description>False positive condition for Kerberoasting</description>
	</rule>
	<rule id="120002" level="0">
		<if_sid>120000</if_sid>
		<field name="win.eventdata.serviceName">\.*\$</field>
		<description>False positive condition for Kerberoasting</description>
	</rule>
	<rule id="120003" level="0">
		<if_sid>120000</if_sid>
		<field name="win.eventdata.targetUserName">\.*\$@\.*</field>
		<description>False positive condition for Kerberoasting</description>
	</rule>

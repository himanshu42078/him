		<description>Connection Attempt TO Tor IP(s)</description>
	</rule>
	<!-- Login success FROM Malware IP(s) -->
	<rule id="101207" level="12">
		<if_group>authentication_success</if_group>
		<list field="srcip" lookup="address_match_key">etc/lists/malware-ip</list>
		<group>attack_stage_Initial_Access,attack_category_Credential_Misuse_/_Abuse,</group>
		<description>Login success FROM Malware IP(s)</description>
	</rule>

	<rule id="101208" level="12">
		<if_group>vpn_login_success</if_group>
		<list field="srcip" lookup="address_match_key">etc/lists/tor-ip</list>

<group name="syslog,pwc_caas,all_client,">
	<!-- PwC Anomaly: Connection Attempt TO Malware IP(s) -->
	<rule id="101204" level="12">
		<if_group>L2R</if_group>
		<list field="dstip" lookup="address_match_key">etc/lists/malware-ip</list>
		<group>attack_stage_Command_and_Control,attack_category_Anomalous_Outbound_Traffic,group_by_data.srcip,</group>
		<description>Connection Attempt TO Malware IP(s)</description>
	</rule>
	<rule id="101205" level="13">
		<if_group>L2R</if_group>
		<list field="dstip" lookup="address_match_key">etc/lists/tor-ip</list>

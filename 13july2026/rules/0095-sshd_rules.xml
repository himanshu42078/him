	<rule id="5717" level="4">
		<if_sid>5700</if_sid>
		<field name="msg">error: Bad prime description in line</field>
		<description>sshd: configuration error (moduli).</description>
	</rule>
	<rule id="5718" level="5">
		<if_sid>5700</if_sid>
		<field name="msg">not allowed because</field>

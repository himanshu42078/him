	<!-- sysmon event 1 - Detect dll run by Rundll32 -->
	<rule id="107200" level="12">
		<if_group>sysmon_event1</if_group>
		<field name="win.eventdata.commandLine">Rundll32.exe\.+.dll</field>
		<description>Detect dll run by Rundll32 - $(win.eventdata.commandLine)</description>
		<group>attack_stage_Execution,attack_category_Suspicious_Command_Execution,groupid_107200,</group>
	</rule>
	<!-- Windows event 4688 - Detect dll run by Rundll32 -->
	<rule id="107201" level="3">
		<if_sid>60103</if_sid>
		<field name="win.system.eventID">^4688$</field>
		<field name="win.eventdata.commandLine">Rundll32.exe\.+.dll</field>

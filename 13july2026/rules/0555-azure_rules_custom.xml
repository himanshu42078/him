
<group name="pwc_caas,Cloud,Azure,all_client,Initial_Access,cloud,">
	<!-- Azure Messages -->
	<!-- Aligned AzureEventhub logs with the same decoder as AzureGraphAPI-json. Eventhub-json is obsolete(after ricoh). -->
	<!--
	<rule id="105000" level="3">
		<decoded_as>AzureGraphAPI-json</decoded_as>
		<description>Azure Messages</description>
	</rule>
	-->
	<rule id="105001" level="0">
		<decoded_as>json</decoded_as>
		<field name="tags">\.*azureeh\.*</field>
		<field name="properties.appDisplayName">\.+</field>
		<description>Azure Messages</description>
	</rule>
	<!-- Intune Device Ownership Change -->
	<rule id="105002" level="13">
		<if_sid>105001</if_sid>
		<field name="operationName">patch ManagedDevice</field>
		<field name="modifiedProperties">ManagedDeviceOwnerType</field>
		<description>Intune Device Ownership Change</description>
		<group>attack_stage_Defense_Evasion,attack_category_Tampering_of_MDM_/_BYOD_Device,</group>
	</rule>
	<!-- Intune Device Passcode/Password Disabled -->
	<rule id="105003" level="13">
		<if_sid>105001</if_sid>
		<field name="operationName">patch DeviceCompliance Policy Update</field>
		<field name="PasscodeRequired">false</field>
		<description>Intune Device Passcode/Password Disabled</description>
		<group>attack_stage_Defense_Evasion,attack_category_Tampering_of_MDM_/_BYOD_Device,</group>
	</rule>
	<!-- Intune Data Encryption Disabled -->
	<rule id="105004" level="13">
		<if_sid>105001</if_sid>
		<field name="operationName">create DeviceCompliancePolicy</field>
		<field name="DataEncryption">false</field>
		<description>Intune Data Encryption Disabled</description>
		<group>attack_stage_Defense_Evasion,attack_category_Tampering_of_MDM_/_BYOD_Device,</group>
	</rule>
	<!-- PwC CaaS: Azure Custom Role Update -->
	<rule id="105005" level="13">
		<if_sid>105001</if_sid>
		<field name="operationName">add role definition</field>
		<description>Azure Custom Role Update</description>
		<group>attack_stage_Persistence,attack_category_Privileged_Account_Misuse_/_Abuse,</group>
	</rule>
	<!-- Azure Policy Update at an unusual time -->
	<rule id="105006" level="13">
		<if_sid>105001</if_sid>
		<field name="operationName">^add policy$|^delete policy$|^update policy$</field>
		<time>01:00-08:00</time>
		<description>Azure Policy Update at an unusual time</description>
		<group>attack_stage_Lateral_Movement,attack_category_Suspected_Identity_Theft,</group>
	</rule>
	<!-- Azure MFA Policy Disable< -->
		<rule id="105007" level="13">
			<if_sid>105001</if_sid>
			<field name="operationName">disable strong authentication</field>
			<description>Azure MFA Policy Disable</description>
			<group>attack_stage_Defense_Evasion,attack_category_Tampering_of_MDM_/_BYOD_Device,</group>
		</rule>
		<!-- Azure Security/Access Policy by unauthorised user-->
		<rule id="105008" level="13">
			<if_sid>105001</if_sid>
			<field name="operationName">Update policy|Add Policy</field>
			<field name="PolicyType">SecurityRiskPolicy|ConditionalAccessPolicy</field>
			<match>!"UserName":"adminfpc@firstpacific.com|pwc@firstpacific.com</match>
			<description>Azure Security/Access Policy by unauthorised user</description>
			<group>attack_stage_Impact,attack_category_Malicious_Tampering_of_System,</group>
		</rule>
		<!-- Azure Admins Role Assign -->
		<rule id="105009" level="13">
			<if_sid>105001</if_sid>
			<field name="operationName">Add member to role|Remove member from role</field>
			<field name="identity">administrator</field>
			<description>Azure Admins Role Assign</description>
			<group>attack_stage_Persistence,attack_category_Privileged_Account_Misuse_/_Abuse,</group>
		</rule>
		<!-- Azure Invite External User -->
		<rule id="105010" level="13">
			<if_sid>105001</if_sid>
			<field name="operationName">Invite External user</field>
			<description>Azure Invite External User</description>
			<group>attack_stage_Persistence,attack_category_Suspicious_Account_Creation,</group>
		</rule>
		<!-- Azure Access Blocked Due to Internal Policy -->
		<rule id="105012" level="13">
			<if_sid>105001</if_sid>
			<field name="operationName">sign-in activity</field>
			<field name="resultDescription">Access has been blocked due to conditional access policies</field>
			<description>Azure Access Blocked Due to Internal Policy</description>
			<group>attack_stage_Lateral_Movement,attack_category_Account_Lockout,</group>
		</rule>
		<!-- Azure MFA Challenge Failure -->
		<rule id="105013" level="13">
			<if_sid>105001</if_sid>
			<field name="operationName">sign-in activity</field>
			<field name="resultType">50074</field>
			<field name="resultDescription">User did not pass the MFA challenge</field>
			<field name="status.additionalDetails">MFA denied</field>
			<match>!"status":{"additionalDetails":"MFA denied; authentication in progress"</match>
			<description>Azure MFA Challenge Failure</description>
			<group>attack_stage_Initial_Access,attack_category_Brute-Forcing,</group>
		</rule>
		<!-- Azure AD Risk Events -->
		<rule id="105014" level="13">
			<if_sid>105001</if_sid>
			<field name="operationName">sign-in activity</field>
			<field name="resultType">50031</field>
			<field name="properties.status.failureReason">TypeunlikelyTravel|anonymizedIPAddress|maliciousIPAddress|unfamiliarFeatures|malwareInfectedIPAddress|suspiciousIPAddress|leakedCredentials|investigationsThreatIntelligence|genericadminConfirmedUserCompromised|mcasImpossibleTravel|mcasSuspiciousInboxManipulationRules|investigationsThreatIntelligenceSigninLinked|maliciousIPAddressValidCredentialsBlockedIP</field>
			<description>Azure AD Risk Events</description>
			<group>attack_stage_Initial_Access,attack_category_Unauthorised_/_Unrecognised_Device,</group>
		</rule>
		<!-- Intune Device Registered -->
		<rule id="105015" level="10">
			<if_matched_sid>105001</if_matched_sid>
			<field name="operationName">Add registered users to device</field>
			<description>Intune Device Registered</description>
		</rule>
		<!-- Intune Device Enrolled -->
		<rule id="105016" level="3">
			<if_sid>105001</if_sid>
			<field name="operationName">Update Device</field>
			<field name="identity">Device Registration Service</field>
			<description>Intune Device Enrolled</description>
		</rule>
		<!-- Intune Device No Longer Managed -->
		<rule id="105017" level="13">
			<if_sid>105001</if_sid>
			<field name="operationName">Device no longer managed</field>
			<field name="PasscodeRequired">false</field>
			<description>Intune Device No Longer Managed</description>
			<group>attack_stage_Defense_Evasion,attack_category_Tampering_of_MDM_/_BYOD_Device,</group>
		</rule>


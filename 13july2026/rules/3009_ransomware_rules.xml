		<field name="win.system.subjectUserSid">ANONYMOUS LOGON</field>
		<field name="win.system.subjectUserName">ANONYMOUS LOGON</field>
		<field name="win.system.passwordLastSet"></field>
        <description>Zerologon Attempt</description>
	</rule>	

	<rule id="300911" level="10">

	<rule id="300908" level="5">
		<if_sid>60106</if_sid>
		<field name="win.eventdata.logonType">^10$</field>
		<time>9 pm - 7 am</time>
		<description>Non-office hour successful Remote login</description>
		<group>attack_stage_Initial_Access,attack_category_Unauthorised_/_Unrecognised_Device,</group>
	</rule>		

	<rule id="300910" level="10">
		<if_sid>60121</if_sid>

        <description>Suspicious ransomware / malicious hacker tool execution</description>
        <group>attack_stage_Execution,attack_category_Malware_Detection,</group>
		<!-- DEV-4624 -->
		<!-- DEV-4798 -->
	</rule>
	<rule id="300901" level="12">
		<if_sid>60103</if_sid>
		<field name="win.system.eventID">^4624$</field>
		<field name="win.eventdata.workstationName">^kali|backbox|parrot|blackarch</field>
		<description>Successful Windows login from Pentesting Tools hosts</description>
        <group>attack_stage_Lateral_Movement,attack_category_Suspected_Identity_Theft,</group>
	</rule>

    <rule id="300902" level="12">
		<if_sid>60103</if_sid>
		<field name="win.system.eventID">^4625$</field>
		<field name="win.eventdata.workstationName">^kali|backbox|parrot|blackarch</field>
		<description>Potential Windows Login attempt from Pentesting Tools hosts</description>
        <group>attack_stage_Initial_Access,attack_category_Brute-Forcing,</group>
	</rule>

    <rule id="300903" level="5">
		<if_sid>60103</if_sid>
		<field name="win.system.eventID">^4688$</field>
		<field name="win.eventdata.newProcessName">:\\\\users\\\\public\\\\\w+.exe$|:\\\\programdata\\\\\w+.exe$|:\\\\perflogs\\\\\w+.exe$</field>
        <description>Suspicious EXE Staging Location detected in command line</description>
        <group>attack_stage_Execution,attack_category_Malware_Detection,</group>
	</rule>

    <rule id="300904" level="12" frequency="10" timeframe="300">
		<if_matched_sid>60111</if_matched_sid>
		<same_field>win.system.computer</same_field>
        <description>Multiple Account Being Disabled/ Deleted in short period of time</description>
        <group>attack_stage_Impact,attack_category_Access_Removal,</group>
	</rule>

	<rule id="300920" level="0">
		<if_sid>300900</if_sid>
		<field name="win.eventdata.commandLine">continuous|continue|sesmcontinst|contid|ContinuumAnalytics|RemoteToMyPC|continuation|Contingency|continuing</field>
        <description>[Whitelist]Legit FPs in Ransomware command line detection</description>
	</rule>

	<rule id="300905" level="4" frequency="10" timeframe="300">
		<if_matched_sid>60121</if_matched_sid>
    	<field name="win.system.eventID">^4742$</field>
		<same_field>win.system.computer</same_field>
        <description>Multiple Computer account changed/deleted in short period of time</description>
	</rule>	

	<rule id="300906" level="12">
		<if_sid>60103</if_sid>
		<field name="win.system.eventID">^4688$</field>
		<field name="win.eventdata.commandLine">\\svchost.exe</field>
        <description>Suspicious Ransomware related command executed</description>
        <group>attack_stage_Execution,attack_category_Malware_Detection,</group>
	</rule>

	<rule id="300922" level="0">
		<if_sid>300906</if_sid>
		<field name="win.eventdata.commandLine">\.:\\\\Windows\\\\System32\\\\|CtxSvcHost</field>
        <description>[Whitelist] Legit FPs in Ransomware command line detection</description>
	</rule>

	<rule id="300907" level="10">
		<if_sid>60002</if_sid>
		<field name="win.system.eventID">^7036$</field>
		<field name="win.eventdata.param1">Kaspersky Security Exploit Prevention Service</field>
		<field name="win.eventdata.param2">stopped|停止</field>
        <description>Anti-virus entered the stopped state</description>
	</rule>	

<!--
This alert will be further analyzed by ElastAlert for new IP with 30 days

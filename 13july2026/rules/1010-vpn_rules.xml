
<!-- Modify it at your will. -->
<group name="pwc_caas,vpn,">
	<rule id="101008" level="12">
		<if_group>vpn_login_success</if_group>
		<list field="srcip" lookup="address_match_key">etc/lists/public-vpn</list>
		<description>Successful VPN login from public VPN IP</description>
		<group>attack_stage_Initial_Access,attack_category_Unauthorised_/_Unrecognised_Device,</group>
		<!-- DEV-4879 -->
	</rule>	
	
	<rule id="101000" level="13">
		<if_group>vpn_login_success</if_group>
		<list field="srcip" lookup="address_match_key">etc/lists/tor-ip</list>
		<description>Successful VPN Login from Tor-IP</description>
		<group>attack_stage_Initial_Access,attack_category_Unauthorised_/_Unrecognised_Device,</group>
	</rule>
	<rule id="101001" level="7">
		<if_group>vpn_login_success</if_group>
		<list field="srcip" lookup="address_match_key">etc/lists/aws_ip_range</list>
		<description>Successful VPN Login from AWS</description>
		<group>attack_stage_Initial_Access,attack_category_Unauthorised_/_Unrecognised_Device,</group>
	</rule>


<group name="pwc_caas,pingan_cloud,cloud,">
	<rule id="143500" level="2">
		<decoded_as>pingan-cloud</decoded_as>
		<description>Group of Pingan Cloud events</description>
	</rule>
	<rule id="143501" level="3">
		<if_sid>143500</if_sid>
		<field name="msg">Login</field>
		<status>Success|Finished</status>
		<description>Pingan Cloud - Logon success</description>
		<group>authentication_success</group>
	</rule>
	<rule id="143502" level="3">
		<if_sid>143500</if_sid>
		<field name="msg">Login</field>
		<status>Fail</status>
		<description>Pingan Cloud - Logon failure</description>
		<group>authentication_failed</group>
	</rule>
	<rule id="143503" level="7">
		<if_sid>143500</if_sid>
		<field name="msg">CreateAccessKey</field>
		<status>Success|Finished</status>
		<description>Pingan Cloud - Create new access key successfully</description>
		<group>attack_stage_Defense_Evasion,attack_category_Suspicious_System_Configuration_Abuse,</group>
	</rule>
	<rule id="143504" level="7">
		<if_sid>143500</if_sid>
		<field name="msg">CreateInstance|RunInstancesByStep</field>
		<status>Success|Finished</status>

		<group>attack_stage_Defense_Evasion,attack_category_Suspicious_System_Configuration_Abuse,</group>
	</rule>
	<rule id="143509" level="7">
		<if_sid>143500</if_sid>
		<field name="msg">DeleteSecurityGroup|RemoveSecurityGroup</field>
		<status>Success|Finished</status>
		<description>Pingan Cloud - Delete security group $(pingan_cloud.EventAudience) successfully</description>

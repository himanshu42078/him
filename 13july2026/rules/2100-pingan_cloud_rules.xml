      <rule id="143512" level="7">
    <if_sid>143500</if_sid>
    <field name="msg">ChangePassword</field>
    <status>Success|Finished</status>
    <description>Pingan Cloud - $(user) Change Password successfully</description>
    <group>attack_stage_Privilege_Escalation,attack_category_Privileged_Account_Misuse_/_Abuse,</group>
  </rule>
</group>

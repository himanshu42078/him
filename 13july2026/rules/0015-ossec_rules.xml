<group name="pwc_caas,ossec,">
    <!-- Move from 1000-common_rules.xml -->
	<!-- Move to DEMO rules, 20230825 meeting -->
	<!-- DEV-5021 -->
	<rule id="531" ignore="7200" level="5" overwrite="yes">
		<if_sid>530</if_sid>
		<match>ossec: output: 'df -P': /dev/</match>
		<regex>100%</regex>
		<description>Partition usage reached 100% (disk space monitor).</description>
		<group>attack_stage_Defense_Evasion,attack_category_Suspicious_System_Configuration_Abuse,</group>
		<group>demo_rules,low_diskspace,pci_dss_10.6.1,gpg13_10.1,gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_AU.6,tsc_CC7.2,tsc_CC7.3,</group>
	</rule>	
	<rule id="100103" ignore="3600" level="5">
		<if_sid>530</if_sid>
		<match>ossec: output: 'df -P': /dev/</match>
		<regex>9\d%</regex>
		<description>Partition usage high (disk space monitor).</description>
		<group>attack_stage_Defense_Evasion,attack_category_Suspicious_System_Configuration_Abuse,auto_escalate_disabled,</group>
		<group>demo_rules,low_diskspace,pci_dss_10.6.1,gpg13_10.1,gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_AU.6,tsc_CC7.2,tsc_CC7.3,DEV-5021,</group>
	</rule>	

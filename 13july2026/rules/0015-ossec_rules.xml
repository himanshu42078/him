	<rule id="504" level="12" overwrite="yes">
		<if_sid>500</if_sid>
		<match>Agent disconnected</match>
		<description>Ossec agent disconnected.</description>
		<group>attack_stage_Impact,attack_category_Unexpected_System_Outage,service_availability,</group>

	</rule>
	<rule id="144001" level="5">
		<if_sid>144000</if_sid>
		<id>^4</id>
		<description>Web server 400 error code.</description>
		<group>attack,pci_dss_6.5,pci_dss_11.4,gdpr_IV_35.7.d,nist_800_53_SA.11,nist_800_53_SI.4,</group>

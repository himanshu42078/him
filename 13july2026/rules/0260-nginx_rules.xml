	<rule id="144004" level="12">
		<if_sid>144000,144008</if_sid>
		<url>../..|..\..|echo;|</url>
		<url>cmd.exe|root.exe|_mem_bin|msadc|/winnt/|/boot.ini|</url>
		<url>/x90/|default.ida|/sumthin|nsiislog.dll|chmod%|wget%|cd%20|</url>
		<url>exec%20|../..//|%5C../%5C|././././|2e%2e%5c%2e|\x5C\x5C|</url>
		<url>../etc/passwd|..\x5Cetc/passwd|%2e%2e%5cetc/passwd|..0x5cetc/passwd</url>
		<description>Common web attack.</description>
		<group>attack,pci_dss_6.5,pci_dss_11.4,pci_dss_6.5.1,gdpr_IV_35.7.d,nist_800_53_SA.11,nist_800_53_SI.4,</group>
	</rule>
	<rule id="144005" level="8">
		<if_sid>144000,144008</if_sid>
		<url>%3Cscript|%3C%2Fscript|script>|script%3E|SRC=javascript|IMG%20|</url>
		<url>%20ONLOAD=|INPUT%20|iframe%20</url>
		<description>XSS (Cross Site Scripting) attempt.</description>
		<group>attack,pci_dss_6.5,pci_dss_11.4,pci_dss_6.5.7,gdpr_IV_35.7.d,nist_800_53_SA.11,nist_800_53_SI.4,</group>
	</rule>
	<rule id="144006" level="12">
		<if_sid>144003, 144004, 144005</if_sid>
		<id>^200</id>
		<description>A web attack returned code 200 (success).</description>
		<group>attack,pci_dss_6.5,pci_dss_11.4,gdpr_IV_35.7.d,nist_800_53_SA.11,nist_800_53_SI.4,</group>
	</rule>
	<rule id="144010" level="12">
		<if_sid>144000</if_sid>
		<url>?-d$|?-s$|?-a$|?-b$|?-w$</url>
		<description>PHP CGI-bin vulnerability attempt.</description>
		<group>attack,pci_dss_6.5,pci_dss_11.4,gdpr_IV_35.7.d,nist_800_53_SA.11,nist_800_53_SI.4,</group>
	</rule>
	<rule id="144009" level="12">
		<if_sid>144000</if_sid>
		<url>+as+varchar</url>
		<regex>%2Bchar\(\d+\)%2Bchar\(\d+\)%2Bchar\(\d+\)%2Bchar\(\d+\)%2Bchar\(\d+\)%2Bchar\(\d+\)</regex>
		<description>MSSQL Injection attempt (/ur.php, urchin.js)</description>

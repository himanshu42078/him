<!-- Modify it at your will. -->
<decoder name="fireeye-fenotify-json">
	<program_name>fenotify</program_name>
</decoder>
<decoder name="fireeye-fenotify-json-fields">
	<parent>fireeye-fenotify-json</parent>
	<plugin_decoder>JSON_Decoder</plugin_decoder>
</decoder>
<decoder name="fireeye-fenotify-json-fields">
	<parent>fireeye-fenotify-json</parent>
  <regex>"dst": {\.*"ip": "(\S+)"</regex>
  <order>dstip</order>
</decoder>
<decoder name="fireeye-fenotify-json-fields">
	<parent>fireeye-fenotify-json</parent>
  <regex>"dst": {\.*"port": "(\d+)"</regex>
  <order>dstport</order>
</decoder>
<decoder name="fireeye-fenotify-json-fields">
	<parent>fireeye-fenotify-json</parent>
  <regex>"src": {\.*"ip": "(\S+)"</regex>
  <order>srcip</order>
</decoder>
<decoder name="fireeye-fenotify-json-fields">
	<parent>fireeye-fenotify-json</parent>
  <regex>"src": {\.*"port": "(\d+)"</regex>
  <order>srcport</order>
</decoder>
<decoder name="fireeye-fenotify-json-fields">
	<parent>fireeye-fenotify-json</parent>
  <regex>"action": "(\S+)"</regex>
  <order>action</order>
</decoder>


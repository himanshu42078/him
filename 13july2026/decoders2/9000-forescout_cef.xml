<decoder name="forescout_cef">
    <program_name>CEF</program_name>
    <prematch>^0\|ForeScout Technologies\|</prematch>
</decoder>

<decoder name="forescout_cef">
    <program_name></program_name>
	<prematch>CEF:\s*0\|ForeScout Technologies\|\.+\|\.+\|\.+\|\.+\|\.+\|</prematch>
</decoder>

<decoder name="forescout_cef">
	<prematch>CEF:\s*0\|ForeScout Technologies\|\.+\|\.+\|\.+\|\.+\|\.+\|</prematch>
</decoder>

<decoder name="forescout_cef_fields">
    <parent>forescout_cef</parent>
    <regex>\d+\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|</regex>
    <order>cef.vendor, cef.product, cef.version, cef.event_class_id, cef.description, cef.severity</order>
</decoder>

<decoder name="forescout_cef_fields">
    <parent>forescout_cef</parent>
    <regex>cs1Label=(\.+) \S+=</regex>
    <order>cef.extensions.cs1Label</order>
</decoder>


<!--
Example:
Mar 15 11:33:49 fwn FW PROTO=6 SRC=165.227.98.205.48022 DST=192.168.9.150.22 ACTION=ACCEPT TOTLEN=60
Mar 15 15:34:14 fwn VS PROTO=6 SRC=185.156.72.52.57425 DST=59.124.31.106.45550 NEW_DST=192.168.6.155.45550 TOTLEN=40
-->


<decoder name="fortiwan">	
  <prematch>FW\s\.*\sACTION=\S+\sTOTLEN=\d+$</prematch>
</decoder>
<decoder name="fortiwan">	
  <prematch>NAT\s\.*\sNEW_SRC=\S+$</prematch>
</decoder>
<decoder name="fortiwan">
  <prematch>AR\s\.*\sAR=\S+\sTOTLEN=\d+$</prematch>
</decoder>
<decoder name="fortiwan">
  <prematch>PR\s\.*\sPR=\S+\sTOTLEN=\d+$</prematch>
</decoder>
<decoder name="fortiwan">	
  <prematch>VS\s\.*\sNEW_DST=\S+\sTOTLEN=\d+$</prematch>
</decoder>
<decoder name="fortiwan">
  <prematch>BM\s\.*\sINPKTS=\d+\sINBYTES=\d+\sOUTPKTS=\d+\sOUTBYTES=\d+\sTOTALPKTS=\d+\sTOTALBYTES=\d+\sDURATION=\d+SECS$</prematch>
</decoder>
<decoder name="fortiwan">
  <prematch>CL\sSRC=\S+\sDROP=\d+$</prematch>
</decoder>
<decoder name="fortiwan">
  <prematch>RL\sRULE=\S+\sDROP=\d+$</prematch>
</decoder>
<decoder name="fortiwan">
  <prematch>CR\s\.*\sNEW_DST=\S+$</prematch>
</decoder>
<decoder name="fortiwan">
  <prematch>MH\sFROM=\S+\sTYPE=\S+\sWLINK=\S+\sREPLY=\S+$</prematch>
</decoder>
<decoder name="fortiwan">
  <prematch>DHCP\sWLINK=\S+\sACTION=\S+</prematch>
</decoder>
<decoder name="fortiwan">
  <prematch>PPPOE\sWLINK=\S+\sACTION=\S+</prematch>
</decoder>
<decoder name="fortiwan">
  <prematch>MAC\s\.*\sBAD_SRC_MAC=\S+$</prematch>
</decoder> 
<decoder name="fortiwan">
  <prematch>MAC\s\.*\sBAD_DST_MAC=\S+$</prematch>
</decoder> 
<decoder name="fortiwan">
  <prematch>TR\s\.*\sGROUP=\S+\sTOTLEN=\d+$</prematch>
</decoder> 
<decoder name="fortiwan">
  <prematch>TUN\sFROM=\S+\sTO=\S+\sACTION=\S+$</prematch>
</decoder> 
<decoder name="fortiwan">
  <prematch>ISAKMP-SA\s\S+\s\S+-\S+$</prematch>
</decoder> 

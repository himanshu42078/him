
<decoder name="crowdstrike_cef">
    <program_name>CEF</program_name>
    <prematch>^0\|CrowdStrike\|</prematch>
</decoder>

<decoder name="crowdstrike_cef">
    <program_name></program_name>
    <prematch>CEF:\s*0\|CrowdStrike\|</prematch>
</decoder>

<decoder name="crowdstrike_cef">
    <prematch>CEF:\s*0\|CrowdStrike\|</prematch>
</decoder>

<!-- Customized fields -->
<decoder name="crowdstrike_cef_fields">
	<parent>crowdstrike_cef</parent>
	<regex>\d+\|(\.+)\|\.+\|\.+\|\.+\|\.+\|\d+\|</regex>
	<order>logsource</order>
</decoder>
<decoder name="crowdstrike_cef_fields">
	<parent>crowdstrike_cef</parent>
	<regex>dhost=(\S+)</regex>
	<order>hostname</order>
</decoder>

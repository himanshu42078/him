<!-- DEV-5774 -->
<decoder name="sangfor_cef">
    <program_name>CEF</program_name>
    <prematch>^0\|SANGFOR\|</prematch>
</decoder>

<decoder name="sangfor_cef">
    <program_name></program_name>
	<prematch>CEF:\s*0\|SANGFOR\|\.+\|\.+\|\.+\|\.+\|\.+\|</prematch>
</decoder>

<decoder name="sangfor_cef">
	<prematch>CEF:\s*0\|SANGFOR\|\.+\|\.+\|\.+\|\.+\|\.+\|</prematch>
</decoder>

<decoder name="sangfor_cef_fields">
    <parent>sangfor_cef</parent>
    <regex>\d+\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|</regex>
    <order>cef.vendor, cef.product, cef.version, cef.event_class_id, cef.description, cef.severity</order>
</decoder>


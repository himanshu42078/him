
<decoder name="incapsula_cef">
    <program_name>CEF</program_name>
    <prematch>^0\|Incapsula\|</prematch>
</decoder>

<decoder name="incapsula_cef">
    <program_name></program_name>
	<prematch>CEF:\s*0\|Incapsula\|\.+\|\.+\|\.+\|\.+\|\.+\|</prematch>
</decoder>

<decoder name="incapsula_cef">
	<prematch>CEF:\s*0\|Incapsula\|\.+\|\.+\|\.+\|\.+\|\.+\|</prematch>
</decoder>

<decoder name="incapsula_cef_fields">
    <parent>incapsula_cef</parent>
    <regex>\d+\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|</regex>
    <order>cef.vendor, cef.product, cef.version, cef.event_class_id, cef.description, cef.severity</order>
</decoder>


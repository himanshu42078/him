<!-- DEV-364 -->
<decoder name="imperva_cef">
	<program_name>CEF</program_name>
	<prematch>^0\|Imperva Inc</prematch>
</decoder>
<decoder name="imperva_fields">
	<parent>imperva_cef</parent>
	<regex>SecureSphere\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|</regex>
	<order>version, eventId, description, severity</order>
</decoder>
<decoder name="imperva_fields">
	<parent>imperva_cef</parent>
	<regex>Attack Analytics\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|</regex>
	<order>version, eventId, description, severity</order>
</decoder>


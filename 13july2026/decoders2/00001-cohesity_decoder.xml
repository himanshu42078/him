<decoder name="cohesity-json">
	<program_name>cluster_audit</program_name>
</decoder>


<decoder name="cohesity-json-fields">
	<parent>cohesity-json</parent>
	<plugin_decoder offset="after_parent">JSON_Decoder</plugin_decoder>
</decoder>

<decoder name="cohesity-json-fields">
	<parent>cohesity-json</parent>
	<regex>"User"\s*:\s*"(\.*)",</regex>
	<order>usr</order>
</decoder>

<decoder name="cohesity-json-fields">
	<parent>cohesity-json</parent>
	<regex>"Action"\s*:\s*"(\.*)",</regex>
	<order>action</order>
</decoder>

<decoder name="cohesity-json-fields">
	<parent>cohesity-json</parent>
	<regex>logged in from \\"(\.*)\\"|log in from \\"(\.*)\\"</regex>
	<order>srcip</order>
</decoder>

<decoder name="cohesity-json-fields">
	<parent>cohesity-json</parent>
	<regex>failed with error: (\.*)"</regex>
	<order>errorMsg</order>
</decoder>



<decoder name="cohesity-fss-json">

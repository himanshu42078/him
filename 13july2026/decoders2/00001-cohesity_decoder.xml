<decoder name="cohesity-fss-json-fields">
	<parent>cohesity-fss-json</parent>
	<regex>"ViewAliasName"\s*:\s*"(\.*)",</regex>
	<order>viewAliasName</order>
</decoder>

<decoder name="cohesity-fss-json-fields">
	<parent>cohesity-fss-json</parent>
	<regex>"Fsid"\sid*:\s*(\.*),</regex>
	<order>fsid</order>
</decoder>

<decoder name="cohesity-fss-json-fields">
	<parent>cohesity-fss-json</parent>
	<regex>"RequestType"\s*:\s*"(\.*)",</regex>

	<regex>"EntityPath"\s*:\s*"(\.*)",|"EntityPath"\s*:\s*"(\.*)"}</regex>
	<order>entityPath</order>
</decoder>

<decoder name="cohesity-fss-json-fields">
	<parent>cohesity-fss-json</parent>
	<regex>"EntityInode"\s*:\s*(\.*),</regex>

<!--
Dec 11 05:38:10 10.30.9.214 sapd[1569]:  <404076> <WARN> |AP T2AP07@10.30.9.214 sapd|  AM 70:3a:0e:e8:21:f0: Radar detected on interface wifi0, channel 108, typeid 7
-->
<decoder name="aruba">
  <program_name></program_name>
	<prematch>\p\d+> \p\d+> \p\S+> \p\.+>|\p\d+> \p\S+> \|AP \.+\|</prematch>
</decoder>

<!--
Apr 28 10:38:55 2023 AS-WIFI-02 isakmpd[3435]: <103063> <3435> <DBUG> <AS-WIFI-02 10.5.6.182>   exchange_start_ikev2 pre-connect check duplicate mapname:default-psk-redundant-master-ipsecmap
-->
<decoder name="aruba">
        <prematch>^\S+ \S+\p\d+\p: \p\d+> \p\d+> \p\S+> \p\.+></prematch>
</decoder>

<decoder name="aruba_fields">
	<parent>aruba</parent>
	<regex>\p(\d+)> \p\d+> \p(\S+)> \p(\S+) (\S+)> (\.+)$</regex>
	<order>aurba.error_number, aruba.severity, aruba.service_name, srcip, aruba.message</order>
</decoder>

<decoder name="aruba_fields">
	<parent>aruba</parent>
	<regex>\p(\d+)> \p(\S+)> \|AP (\S+)@(\S+) sapd\| (\.+)$</regex>
	<order>aurba.error_number, aruba.severity, mac_address, srcip, aruba.message</order>
</decoder>

<decoder name="aruba_fields">
	<parent>aruba</parent>
	<regex>srcip=(\S+)</regex>
	<order>srcip</order>
</decoder>
<decoder name="aruba_fields">
	<parent>aruba</parent>
	<regex>srcport=(\S+)</regex>
	<order>srcport</order>
</decoder>
<decoder name="aruba_fields">
	<parent>aruba</parent>
	<regex>dstip=(\S+)</regex>
	<order>dstip</order>
</decoder>
<decoder name="aruba_fields">
	<parent>aruba</parent>
	<regex>dstport=(\S+),</regex>
	<order>dstport</order>
</decoder>
<decoder name="aruba_fields">
	<parent>aruba</parent>
	<regex>action=(\.+),</regex>
	<order>action</order>
</decoder>

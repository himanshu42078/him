<decoder name="GLP-win">
	<prematch>win-server-sz</prematch>
</decoder>
<decoder name="GLP-win">
	<prematch>winlogbeat</prematch>
</decoder>
<decoder name="GLP-win-field">
	<parent>GLP-win</parent>
	<prematch>content=</prematch>
	<plugin_decoder offset="after_prematch">JSON_Decoder</plugin_decoder>
</decoder>
<decoder name="GLP-win-field">
	<parent>GLP-win</parent>
	<regex>\d (\d+-\d+-\d+T\d+:\d+:\d+.\d+\S+) (\S+) (\S+)</regex>
	<order>timestamp,logsource,region</order>
</decoder>
<!--
DEV-4012, Not A Standard CEF
-->

<decoder name="rsa_cef">
    <program_name>CEF</program_name>
    <prematch>^0\|RSA\|NetWitness ESA\|\.+\|</prematch>
</decoder>

<decoder name="rsa_cef">
    <program_name></program_name>
	<prematch>CEF:\s*0\|RSA\|NetWitness ESA\|\.+\|\.+\|\.+\|\.+\|</prematch>
</decoder>

<decoder name="rsa_cef">
	<prematch>CEF:\s*0\|RSA\|NetWitness ESA\|\.+\|\.+\|\.+\|\.+\|</prematch>
</decoder>

<decoder name="rsa_cef_fields">
    <parent>rsa_cef</parent>
    <regex>\d+\|(\.+)\|(\.+)\|(\.+)\|</regex>
    <order>cef.vendor, cef.product, cef.version</order>
</decoder>

<decoder name="rsa_cef_fields">
    <parent>rsa_cef</parent>
    <regex>\Wreceived time=(\.*),|\Wreceived time=(\.*)$</regex>
    <order>cef.extensions.received_time</order>
</decoder>

<decoder name="rsa_cef_fields">
    <parent>rsa_cef</parent>
    <regex>\Wseverity=(\.*),|\Wseverity=(\.*)$</regex>
    <order>cef.extensions.severity</order>
</decoder>

<decoder name="rsa_cef_fields">
    <parent>rsa_cef</parent>
    <regex>\Walert name=(\.*),|\Walert name=(\.*)$</regex>
    <order>cef.extensions.alert_name</order>
</decoder>

<decoder name="rsa_cef_fields">
    <parent>rsa_cef</parent>
    <regex>\WTraffic Direction=(\.*),|\WTraffic Direction=(\.*)$</regex>
    <order>cef.extensions.traffic_direction</order>
</decoder>

<decoder name="rsa_cef_fields">
    <parent>rsa_cef</parent>
    <regex>\WSource IP=(\.*),|\WSource IP=(\.*)$</regex>
    <order>srcip</order>
</decoder>

<decoder name="rsa_cef_fields">
    <parent>rsa_cef</parent>
    <regex>\WDestination IP=(\.*),|\WDestination IP=(\.*)$</regex>
    <order>dstip</order>
</decoder>

<decoder name="rsa_cef_fields">
    <parent>rsa_cef</parent>
    <regex>\WTCP Dport=(\.*),|\WTCP Dport=(\.*)$</regex>
    <order>dstport</order>
</decoder>

<decoder name="rsa_cef_fields">
    <parent>rsa_cef</parent>
    <regex>\WIP Protocol=(\.*),|\WIP Protocol=(\.*)$</regex>
    <order>protocol</order>
</decoder>

<decoder name="rsa_cef_fields">
    <parent>rsa_cef</parent>
    <regex>\WService=(\.*),|\WService=(\.*)$</regex>
    <order>cef.extensions.service</order>
</decoder>
<!-- aws Decoder The purpose of this decoder is to obtain standardized field-->
<decoder name="aws-waf">
	<prematch>{"integration": "aws", "aws":\.+"source": "waf"</prematch>
</decoder>
<decoder name="aws-waf-fields">
	<parent>aws-waf</parent>
	<regex>"integration": "(\.+)"</regex>
	<order>integration</order>
</decoder>
<decoder name="aws-waf-fields">
	<parent>aws-waf</parent>
	<regex>"source": "(\.+)"</regex>
	<order>aws.source</order>
</decoder>
<decoder name="aws-waf-fields">
	<parent>aws-waf</parent>
	<regex>"webaclId": "arn:aws:waf\S*:(\S*):(\d*):\.*"</regex>
	<order>aws.awsRegion,aws.aws_account_id</order>
</decoder>

<!-- log_info -->
<decoder name="aws-waf-fields">
	<parent>aws-waf</parent>
	<regex>"s3bucket": "(\.+)"</regex>
	<order>aws.log_info.s3bucket</order>
</decoder>
<decoder name="aws-waf-fields">
	<parent>aws-waf</parent>
	<regex>"s3bucket": "(\.*)"</regex>
	<order>logsource</order>
</decoder>
<decoder name="aws-waf-fields">
	<parent>aws-waf</parent>
	<regex>"log_file": "(\.*)"</regex>
	<order>aws.log_info.log_file</order>
</decoder>


<!--
-  Wazuh decoders CarbonBlack
{"direction":"Outbound","dns_name":"stats.wordpress.com","local_ip":"-1407832499","local_port":"60011","port":"60011","protocol":"TCP","remote_ip":"-1073721830","remote_port":"80"}
-->
<decoder name="CarbonBlack">
	<prematch>LEEF:\.*\|CB\|CB\|</prematch>
</decoder>
<decoder name="CarbonBlack">
	<program_name>LEEF</program_name>
	<prematch>\d.\d\|CB\|CB\|</prematch>
</decoder>
<!--<decoder name="CarbonBlack-fields">
	<parent>CarbonBlack</parent>
	<prematch>ioc_attr=</prematch>
	<plugin_decoder offset="after_prematch">JSON_Decoder</plugin_decoder>
</decoder>
-->
<decoder name="CarbonBlack-fields">
	<parent>CarbonBlack</parent>
	<regex>\d.\d\|CB\|CB\|(\S+)\|(\S+)\|</regex>
	<order>cb.version, cb.type</order>
</decoder>
<decoder name="CarbonBlack-fields">
	<parent>CarbonBlack</parent>
	<regex>"direction":"(\.*)"</regex>
	<order>cb.direction</order>
</decoder>
<decoder name="CarbonBlack-fields">
	<parent>CarbonBlack</parent>
	<regex>"dns_name":"(\.*)"</regex>
	<order>cb.dns_name</order>
</decoder>
<!--
<decoder name="CarbonBlack-fields">
	<parent>CarbonBlack</parent>
	<regex>"local_ip":"(\.*)"</regex>
	<order>srcip</order>
</decoder>
Not in correct format, using interface_ip as the srcip instead.
-->
<decoder name="CarbonBlack-fields">
	<parent>CarbonBlack</parent>
	<regex>"local_port":"(\.*)"</regex>
	<order>srcport</order>
</decoder>
<decoder name="CarbonBlack-fields">
	<parent>CarbonBlack</parent>
	<regex>"protocol":"(\.*)"</regex>
	<order>cb.protocol</order>
</decoder>
<!--
<decoder name="CarbonBlack-fields">
	<parent>CarbonBlack</parent>
	<regex>"remote_ip":"(\.*)"</regex>
	<order>dstip</order>
</decoder>
Not useful, since the IP address is not in correct form. Using ioc_value as dstip instead
-->
<decoder name="CarbonBlack-fields">
	<parent>CarbonBlack</parent>
	<regex>"remote_port":"(\.*)"</regex>
	<order>dstport</order>
</decoder>


<decoder name="thycoticsoftware_cef">
    <program_name>CEF</program_name>
    <prematch>^0\|Thycotic Software\|</prematch>
</decoder>

<decoder name="thycoticsoftware_cef">
    <program_name></program_name>
	<prematch>CEF:\s*0\|Thycotic Software\|\.+\|\.+\|\.+\|\.+\|\.+\|</prematch>
</decoder>

<decoder name="thycoticsoftware_cef">
	<prematch>CEF:\s*0\|Thycotic Software\|\.+\|\.+\|\.+\|\.+\|\.+\|</prematch>
</decoder>

<decoder name="thycoticsoftware_cef_fields">
    <parent>thycoticsoftware_cef</parent>
    <regex>\d+\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|</regex>
    <order>cef.vendor, cef.product, cef.version, cef.event_class_id, cef.description, cef.severity</order>
</decoder>

<decoder name="thycoticsoftware_cef_fields">
    <parent>thycoticsoftware_cef</parent>
    <regex>msg=(\.+) \S+=</regex>
    <order>cef.extensions.msg</order>
</decoder>


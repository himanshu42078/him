<!-- Modify it at your will. -->
<decoder name="nexg">
        <program_name>session</program_name>
        <prematch>Proto:\d+, Policy:\S+, Rule:\d+, Type:\S+, Src:\S+, Dst:\S+, Spt_c:\d+, Dpt_t:\d+, Bytes:\d+, Packets:\d+, Repl_Src:\S+, Repl_Dst:\S+, Repl_Spt_c:\d+, Repl_Dpt_t:\d+, Repl_Bytes:\d+, Repl_Packets:\d+, Count:\d+, Start_Time:\.+, End_Time:\.+</prematch>
</decoder>

<decoder name="nexg">
        <program_name>ipsec</program_name>
        <prematch>SA_Type:\S+, Local_IP:\S+, Local_ID:\S+, Remote_IP:\S+, Remote_ID:\S+, Virtual_IP:\S+, Negotiation:\S+, SA_Flags:\S+, Auth_Type:\S+, Encryption:\S+, Hash:\S+, Lifetime:\d+s, Local_TS:\S+, Remote_TS:\S+</prematch>
</decoder>

<decoder name="nexg">
        <program_name>iked</program_name>
        <prematch>\d+\p\w\w\w\p</prematch>
</decoder>

<!-- System/Audit Log -->
<!-- <15> Jun 10 13:42:40 STAT: message [%ld seconds delayed] -->
<decoder name="nexg-stat">	
    <parent>nexg</parent>
    <prematch offset="after_parent">STAT:\s*\.+ [%</prematch>
	<regex>(STAT):\s*(\.+) [%</regex>
	<order>nexg.logType, nexg.msg</order>
</decoder>

<!-- Common Fields -->
<decoder name="nexg-field">
	<parent>nexg</parent>
	<regex>\p\d+\p\s*\S+\s*\d+ \d+:\d+:\d+ (\S+):</regex>
	<order>nexg.logType</order>
</decoder>


<decoder name="vmwarecarbonblack_cef">
    <program_name>CEF</program_name>
    <prematch>^0\|VMware Carbon Black\|</prematch>
</decoder>

<decoder name="vmwarecarbonblack_cef">
    <program_name></program_name>
    <prematch>CEF:\s*0\|VMware Carbon Black\|</prematch>
</decoder>

<decoder name="vmwarecarbonblack_cef">
    <prematch>CEF:\s*0\|VMware Carbon Black\|</prematch>
</decoder>

<decoder name="vmwarecarbonblack_cef_fields">
    <parent>vmwarecarbonblack_cef</parent>
    <regex>\d+\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|</regex>
    <order>cef.vendor, cef.product, cef.version, cef.event_class_id, cef.description, cef.severity</order>
</decoder>


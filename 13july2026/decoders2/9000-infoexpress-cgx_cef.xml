<decoder name="infoexpress_cef">
    <program_name>CEF</program_name>
    <prematch>^0\|Infoexpress\|</prematch>
</decoder>

<decoder name="infoexpress_cef">
    <program_name></program_name>
	<prematch>CEF:\s*0\|Infoexpress\|\.+\|\.+\|\.+\|\.+\|\.+\|</prematch>
</decoder>

<decoder name="infoexpress_cef">
	<prematch>CEF:\s*0\|Infoexpress\|\.+\|\.+\|\.+\|\.+\|\.+\|</prematch>
</decoder>

<decoder name="infoexpress_cef_fields">
    <parent>infoexpress_cef</parent>
    <regex>\d+\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|</regex>
    <order>cef.vendor, cef.product, cef.version, cef.event_class_id, cef.description, cef.severity</order>
</decoder>

<decoder name="infoexpress_cef_fields">
    <parent>infoexpress_cef</parent>
    <regex>shost=(\.+) \S+=</regex>
    <order>cef.extensions.shost</order>
</decoder>

<decoder name="infoexpress_cef_fields">
    <parent>infoexpress_cef</parent>
    <regex>src=(\.+) \S+=</regex>
    <order>cef.extensions.src</order>
</decoder>

<decoder name="infoexpress_cef_fields">
    <parent>infoexpress_cef</parent>
    <regex>src=(\.+) \S+=</regex>
    <order>srcip</order>
</decoder>

<decoder name="infoexpress_cef_fields">
    <parent>infoexpress_cef</parent>
    <regex>start=(\.+) \S+=</regex>
    <order>cef.extensions.start</order>
</decoder>

<decoder name="infoexpress_cef_fields">
    <parent>infoexpress_cef</parent>
    <regex>start=(\.+) \S+=</regex>
    <order>event_time</order>
</decoder>

<decoder name="infoexpress_cef_fields">
    <parent>infoexpress_cef</parent>
    <regex>msg=(\.+) \S+=</regex>
    <order>cef.extensions.msg</order>
</decoder>

<decoder name="infoexpress_cef_fields">
    <parent>infoexpress_cef</parent>
    <regex>suser=(\.+) \S+=</regex>
    <order>cef.extensions.suser</order>
</decoder>

<decoder name="infoexpress_cef_fields">
    <parent>infoexpress_cef</parent>
    <regex>suser=(\.+) \S+=</regex>
    <order>srcuser</order>
</decoder>

<decoder name="infoexpress_cef_fields">
    <parent>infoexpress_cef</parent>
    <regex>cat=(\.*) \S+=|cat=(\.*)$</regex>

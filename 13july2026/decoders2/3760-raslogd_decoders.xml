<decoder name="raslogd">
    <program_name>raslogd</program_name>
    <prematch>^AUDIT, \d\d\d\d/\d\d/\d\d-\d\d:\d\d:\d\d \S+, [\S+],</prematch>
</decoder>

<decoder name="raslogd-fields">
    <parent>raslogd</parent>
    <regex>AUDIT, \.+, [(\S+)], (\S+), (\S+), (\S+)/(\S+)/(\S+)/(\S+)/(\S+), ad_0/(\S+)/(\.+),</regex>
    <order>event_id, severity, event_class, user_id, role, srcip, interface, application_name, admin_domain, switch_name</order>
</decoder>

<decoder name="raslogd-fields">
    <parent>raslogd</parent>
    <regex>, Event: (\S+),</regex>
    <order>event</order>
</decoder>
<decoder name="raslogd-fields">
    <parent>raslogd</parent>
    <regex>, Status: (\S+),</regex>
    <order>status</order>
</decoder>
<decoder name="raslogd-fields">
    <parent>raslogd</parent>
    <regex>, Info: (\.+),|, Info: (\.+).</regex>
    <order>info</order>
</decoder>
<decoder name="raslogd-fields">
    <parent>raslogd</parent>
    <regex>, CLI: (\S+)</regex>
    <order>cli</order>
</decoder>
<decoder name="raslogd-fields">
    <parent>raslogd</parent>
    <regex>, IP Addr: (\S+)</regex>
    <order>srcip</order>
</decoder>
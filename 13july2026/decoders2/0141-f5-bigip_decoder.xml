<decoder name="f5-bigip-fields">
    <parent>f5-bigip</parent>
    <regex>(\S+) (\S+)\p(\d+)\p: \.+Common:\S+: (\.+)|(\S+) (\S+)\p(\d+)\p: (\.+)</regex>
    <order>level,service,pid,message</order>
</decoder>
<decoder name="f5-bigip-fields">
    <parent>f5-bigip</parent>
    <regex>\S+\p\d+\p: (\d+):(\d+):</regex>
    <order>code, sub_code</order>
</decoder>
<decoder name="f5-bigip-fields">
    <parent>f5-bigip</parent>
    <regex>(\S+) (\S+):(\d+) -> (\S+):(\d+)</regex>
    <order>protocol, srcip, srcport, dstip, dstport</order>
</decoder>
<decoder name="f5-bigip-fields">
    <parent>f5-bigip</parent>
    <regex>AUDIT - pid=(\d+) user=(\.*) folder=(\.*) module=(\.*) status=(\.*) cmd_data=(\.*)</regex>
    <order>pid, dstuser, folder, module, status, cmd_data</order>
</decoder>
<decoder name="f5-bigip-fields">
    <parent>f5-bigip</parent>
    <regex>client IP (\S+)|Client IP: (\S+)</regex>

<!-- ####### Opswat - Melco Log start from here ####### -->

<decoder name="opswat_melco">
	<prematch>CEF:\s*0\|OPSWAT\|\.+\|\.+\|\.+\|\.+\|\.+\|</prematch>
</decoder>

<decoder name="opswat-fields">
    <parent>opswat_melco</parent>
	<regex>(\d\d\d\d-\d\d-\d\dT\d\d:\d\d:\d\d\w)\s+(\S+)</regex>
	<order>timestamp, hostname</order>
</decoder>

<decoder name="opswat-fields">
    <parent>opswat_melco</parent>
	<regex>CEF:(\d+)\|(OPSWAT)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\d+)\|(\.+)$</regex>
	<order>cef_version, device_vendor, device_product, device_version, signature_id, subject_name, severity, extension</order>
</decoder>

<decoder name="opswat-fields">
    <parent>opswat_melco</parent>
	<regex>OMSuser=(\.+)\sOMS|OMSuser=(\.+)$</regex>
	<order>OMSuser</order>
</decoder>


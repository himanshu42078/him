<decoder name="h3c">
  <prematch>devicename=H3C|\d\d\d\d-\d\d-\d\d \d\d:\d\d:\d\d DDoS:\S+:H3C</prematch>
</decoder>
<decoder name="h3c_fields">
  <parent>h3c</parent>
  <regex>DDoS:\S+:(\.*) \S+:(\.*) \S+:(\.*) \S+:(\.*) \S+:(\.*) \S+:(\.*) </regex>
  <order>devicename,srcip,srcport,dstip,dstport,protocol</order>
</decoder>
<decoder name="h3c_fields">
  <parent>h3c</parent>
  <regex offset="after_regex">\S+:(\.*) \S+:(\.*) \S+:(\.*) CDN ip:(\.*) XFF ip:(\.*) \S+:(\.*) \S+:(\.*)</regex>
  <order>attack_type,url,url_domain,cdn_ip,xff_ip,severity,attack_freq</order>
</decoder>
<decoder name="h3c_fields">

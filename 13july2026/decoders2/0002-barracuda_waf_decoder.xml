<decoder name="barracuda_waf">
  <prematch>\|Barracuda\|</prematch>
  <program_name>CEF</program_name>
</decoder>
<decoder name="barracuda_waf_fields">
  <parent>barracuda_waf</parent>
  <regex>\d+\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|</regex>
	<order>vendor, product, version, eventId, description, severity</order>
</decoder>
<decoder name="barracuda_waf_fields">
  <parent>barracuda_waf</parent>
  <regex>src=(\S+) </regex>
  <order>srcip</order>
</decoder>

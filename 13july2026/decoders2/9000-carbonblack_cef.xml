<!-- DEV-642 -->
<!-- General CarbonBlack Decoder in CEF Format -->
<!-- 
VMWare Carbon Black Protection v8.1
Odd version of VMWare Carbon Black App Control
-->
<!--
Reference:
https://community.carbonblack.com/t5/Documentation-Downloads/CB-Protection-Events-Guide-v8-1-10/ta-p/91842
-->
<decoder name="carbonblack_cef">
    <program_name>CEF</program_name>
    <prematch>^0\|Carbon Black\|</prematch>
</decoder>

<decoder name="carbonblack_cef">
    <program_name></program_name>
    <prematch>CEF:\s*0\|Carbon Black\|</prematch>
</decoder>

<decoder name="carbonblack_cef">
    <prematch>CEF:\s*0\|Carbon Black\|</prematch>
</decoder>

<decoder name="carbonblack_cef_fields">
    <parent>carbonblack_cef</parent>
    <regex>\d+\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|</regex>
    <order>cef.vendor, cef.product, cef.version, cef.event_class_id, cef.description, cef.severity</order>
</decoder>

<decoder name="carbonblack_cef_fields">
    <parent>carbonblack_cef</parent>
    <regex>\WexternalId="(\.*)" \S+=|\WexternalId="(\.*)"$|\WexternalId=(\.*) \S+=|\WexternalId=(\.*)$</regex>
    <order>cef.extensions.externalId</order>
</decoder>


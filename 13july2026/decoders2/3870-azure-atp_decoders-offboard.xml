<decoder name="azure-atp">
    <program_name>cef</program_name>
    <prematch>0\|Microsoft\|Azure ATP\|\d+.\d+.\d+.\d+\|</prematch>
</decoder>
<decoder name="azure-atp-fields">
    <parent>azure-atp</parent>
    <regex>0\|(\S+)\|(\.+)\|(\S+)\|(\S+)\|(\.+)\|(\d+)</regex>
    <order>vendor,product,version, eventId, description, severity</order>
</decoder>
<decoder name="azure-atp-fields">
    <parent>azure-atp</parent>
    <regex>start=(\.+) \S+=</regex>
    <order>start</order>
</decoder>
<decoder name="azure-atp-fields">
    <parent>azure-atp</parent>
    <regex>app=(\.+) \S+=</regex>
    <order>app</order>
</decoder>
<decoder name="azure-atp-fields">
    <parent>azure-atp</parent>
    <regex>shost=(\.+) \S+=</regex>
    <order>shost</order>
</decoder>
<decoder name="azure-atp-fields">
    <parent>azure-atp</parent>
    <regex>shostfqdn=(\.*) \S+=</regex>
    <order>shostfqdn</order>
</decoder>
<decoder name="azure-atp-fields">
    <parent>azure-atp</parent>
    <regex>msg=(\.+) \S+=</regex>
    <order>msg</order>
</decoder>
<decoder name="azure-atp-fields">
    <parent>azure-atp</parent>
    <regex>externalId=(\.+) \S+=</regex>
    <order>externalId</order>
</decoder>
<decoder name="azure-atp-fields">
    <parent>azure-atp</parent>
    <regex>cs1Label=(\.+) \S+=</regex>
    <order>cs1Label</order>
</decoder>
<decoder name="azure-atp-fields">
    <parent>azure-atp</parent>
    <regex>cs1=(\.+) \S+=</regex>
    <order>cs1</order>
</decoder>
<decoder name="azure-atp-fields">
    <parent>azure-atp</parent>
    <regex>cs2Label=(\.+) \S+=</regex>
    <order>cs2Label</order>
</decoder>
<decoder name="azure-atp-fields">
    <parent>azure-atp</parent>
    <regex>cs2=(\.+) \S+=</regex>
    <order>cs2</order>
</decoder>
<decoder name="azure-atp-fields">
    <parent>azure-atp</parent>
    <regex>cs3Label=(\.+) \S+=</regex>
    <order>cs3Label</order>
</decoder>
<decoder name="azure-atp-fields">
    <parent>azure-atp</parent>
    <regex>cs3=(\S+)</regex>
    <order>cs3</order>
</decoder>
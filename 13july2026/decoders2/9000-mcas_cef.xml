
<decoder name="mcas_cef">
    <program_name>CEF</program_name>
    <prematch>^0\|MCAS\|</prematch>
</decoder>

<decoder name="mcas_cef">
    <program_name></program_name>
    <prematch>CEF:\s*0\|MCAS\|</prematch>
</decoder>

<decoder name="mcas_cef">
    <prematch>CEF:\s*0\|MCAS\|</prematch>
</decoder>

<decoder name="mcas_cef_fields">
    <parent>mcas_cef</parent>
    <regex>\d+\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|</regex>
    <order>cef.vendor, cef.product, cef.version, cef.event_class_id, cef.description, cef.severity</order>
</decoder>

<decoder name="mcas_cef_fields">

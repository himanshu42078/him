<decoder name="paloalto-firewall">
	<prematch>0\|Palo Alto Networks\|\S+\|\S+\|\S+\|\S+\|\d+\|</prematch>
	<program_name>CEF</program_name>
</decoder>

<decoder name="paloalto-firewall">
	<prematch>CEF:0\|palo alto networks\|\S+\|\S+\|\S+\|\S+\|\d+\|</prematch>
</decoder>

<!-- COMMON -->
<decoder name="paloalto-firewall-fields">
	<parent>paloalto-firewall</parent>
	<regex>\d+\|(\.+)\|(\.+)\|(\S+)\|(\.+)\|(\.+)\|(\d+)\|</regex>
	<order>vendor, product, version, type, subtype, severity</order>
</decoder>


<!-- ####### AML Log User Logon Table start from here ####### -->


<decoder name="AMLUserLogon">
    <prematch>"AMLUserLogonHistory": {</prematch>
</decoder>

<decoder name="AMLUserLogon-fields">
    <parent>AMLUserLogon</parent>
    <regex offset="after_parent">"authStatus":\s(\.*),</regex>
    <order>authStatus</order>
</decoder>

<decoder name="AMLUserLogon-fields">
    <parent>AMLUserLogon</parent>
    <regex offset="after_parent">"eventTime":\s"(\.*)",</regex>
    <order>eventTime</order>
</decoder>

<decoder name="AMLUserLogon-fields">
    <parent>AMLUserLogon</parent>
    <regex offset="after_parent">"logonAttempt":\s(\.*),</regex>
    <order>logonAttempt</order>
</decoder>

<decoder name="AMLUserLogon-fields">
    <parent>AMLUserLogon</parent>
    <regex offset="after_parent">"machineName":\s"(\.*)",</regex>
    <order>machineName</order>
</decoder>

<decoder name="AMLUserLogon-fields">
    <parent>AMLUserLogon</parent>
    <regex offset="after_parent">"reason":\s"(\.*)",|reason":\s(\.*),</regex>
    <order>reason</order>
</decoder>

<decoder name="AMLUserLogon-fields">
    <parent>AMLUserLogon</parent>
    <regex offset="after_parent">"userID":\s(\.*),</regex>
    <order>userID</order>
</decoder>

<decoder name="AMLUserLogon-fields">
    <parent>AMLUserLogon</parent>
    <regex offset="after_parent">"userName":\s"(\.*)"</regex>
    <order>srcuser</order>
</decoder>



<decoder name="lastline_cef">
    <program_name>CEF</program_name>
    <prematch>^0\|Lastline\|</prematch>
</decoder>

<decoder name="lastline_cef">
    <program_name></program_name>
	<prematch>CEF:\s*0\|Lastline\|\.+\|\.+\|\.+\|\.+\|\.+\|</prematch>
</decoder>

<decoder name="lastline_cef">
	<prematch>CEF:\s*0\|Lastline\|\.+\|\.+\|\.+\|\.+\|\.+\|</prematch>
</decoder>

<decoder name="lastline_cef_fields">
    <parent>lastline_cef</parent>
    <regex>\d+\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|</regex>
    <order>cef.vendor, cef.product, cef.version, cef.event_class_id, cef.description, cef.severity</order>
</decoder>

<decoder name="lastline_cef_fields">
    <parent>lastline_cef</parent>
    <regex>cat=(\.+) \S+=</regex>
    <order>cef.extensions.cat</order>
</decoder>

<decoder name="lastline_cef_fields">
    <parent>lastline_cef</parent>
    <regex>cn1=(\.+) \S+=</regex>
    <order>cef.extensions.cn1</order>
</decoder>

<decoder name="lastline_cef_fields">
    <parent>lastline_cef</parent>
    <regex>cn1Label=(\.+) \S+=</regex>
    <order>cef.extensions.cn1Label</order>
</decoder>


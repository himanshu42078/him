<decoder name="a10logd">
	<program_name>a10logd</program_name>
	<prematch>^[audit log]\p\d+\p </prematch>
</decoder>

<decoder name="a10logd-fields">
	<parent>a10logd</parent>
	<regex>^[(\.+)]\p(\d+)\p (\.+)</regex>
	<order>module_name,severity,msg</order>
</decoder>
<decoder name="a10logd-fields">
	<parent>a10logd</parent>
	<regex>^[\.+]\p\d+\p\s+\.+\s*[(\.+)] \S+: [\d+:(\d+.\d+.\d+.\d+):(\d+)]</regex>
	<order>dstuser,srcip,srcport</order>
</decoder>
<decoder name="a10logd-fields">
	<parent>a10logd</parent>
	<regex>username: (\S+),</regex>
	<order>dstuser</order>
</decoder>
<decoder name="a10logd-fields">
	<parent>a10logd</parent>
	<regex>remote host: (\d+.\d+.\d+.\d+)</regex>
	<order>srcip</order>
</decoder>
<decoder name="a10logd-fields">
	<parent>a10logd</parent>
	<regex>POST: (\S+)|GET: (\S+)</regex>
	<order>url</order>
</decoder>
<decoder name="SharpPoint">
    <prematch>^"\d+","\d+-\d+-\d+ \d\d:\d\d:\d\d","\d+-\d+-\d+ \d\d:\d\d:\d\d","\.*","\d+","\.+","\.*","\.+"$</prematch>
</decoder>
<decoder name="SharpPoint-fields">
    <parent>SharpPoint</parent>
    <regex>^"(\d+)","(\.+)","(\.+)","(\.*)","(\d+)","(\.+)","(\.*)","(\.+)"$</regex>
    <order>log_no,log_time,bus_date,dstuser,action_id,log_message,new_message,error_no</order>
</decoder>
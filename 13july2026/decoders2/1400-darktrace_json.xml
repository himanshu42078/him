<decoder name="darktrace-json-fields">
	<parent>darktrace-json</parent>
	<regex>"device":{\.*"ip":"(\.*)"</regex>
	<order>srcip</order>
</decoder>
<decoder name="darktrace-json-fields">
	<parent>darktrace-json</parent>
	<regex>"device":{\.*"hostname":"(\.*)"</regex>
	<order>system_name</order>
</decoder>
<decoder name="darktrace-json-fields">
	<parent>darktrace-json</parent>
	<regex>"device":{\.*"credentials":[(\.*)]</regex>
	<order>dstuser</order>
</decoder>
<decoder name="darktrace-json-fields">
	<parent>darktrace-json</parent>
	<regex>"type":"externalHost","values":[{"hostname":"\S+","ip":"(\d+.\d+.\d+.\d+)"}]</regex>
	<order>dstip</order>
</decoder>

<decoder name="darktrace-json-fields">
	<parent>darktrace-json</parent>
	<regex>"breachDevices":[{"identifier":\S+,"hostname":\S+,"ip":"(\d+.\d+.\d+.\d+)",</regex>
	<order>srcip</order>
</decoder>


<decoder name="nnt_cef">
    <program_name>CEF</program_name>
    <prematch>^0\|NNT\|</prematch>
</decoder>

<decoder name="nnt_cef">
    <program_name></program_name>
	<prematch>CEF:\s*0\|NNT\|\.+\|\.+\|\.+\|\.+\|\.+\|</prematch>
</decoder>

<decoder name="nnt_cef">
	<prematch>CEF:\s*0\|NNT\|\.+\|\.+\|\.+\|\.+\|\.+\|</prematch>
</decoder>

<decoder name="nnt_cef_fields">
    <parent>nnt_cef</parent>
    <regex>\d+\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|</regex>
    <order>cef.vendor, cef.product, cef.version, cef.event_class_id, cef.description, cef.severity</order>
</decoder>

<decoder name="nnt_cef_fields">
    <parent>nnt_cef</parent>
    <regex>dvchost=(\.+) \S+=</regex>
    <order>cef.extensions.dvchost</order>
</decoder>

<decoder name="nnt_cef_fields">
    <parent>nnt_cef</parent>
    <regex>rt=(\.+) \S+=</regex>
    <order>cef.extensions.rt</order>
</decoder>

<decoder name="nnt_cef_fields">
    <parent>nnt_cef</parent>
    <regex>rt=(\.+) \S+=</regex>
    <order>event_time</order>
</decoder>


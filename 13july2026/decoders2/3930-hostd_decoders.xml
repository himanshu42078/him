<decoder name="hostd">
    <program_name>hostd</program_name>
</decoder>

<decoder name="hostd-fields">
    <parent>hostd</parent>
    <regex>^(\S+) \S+ [\S+ sub=(\S+) opID=(\S+) user=\.*] Event (\d*) : (\.*)|^(\S+) \S+ [\S+ sub=(\S+) opID=(\S+)] Event (\d*) : (\.*)</regex>
    <order>severity, sub, opid, event_number, msg</order>
</decoder>
<decoder name="hostd-fields">
    <parent>hostd</parent>
    <regex>^(\S+) \S+ [\S+ sub=(\S+) opID=(\S+) user=(\S+)] Task (\S+) : (\.*)</regex>
    <order>severity, sub, opid, srcuser, action, msg</order>
</decoder>
<decoder name="hostd-fields">
    <parent>hostd</parent>
    <regex>User (\S+)@(\d+.\d+.\d+.\d+) logged out \(\.*user agent: (\S+)\)|User (\S+)@(\d+.\d+.\d+.\d+) logged in as (\S+)</regex>
    <order>srcuser, srcip, user_agent</order>
</decoder>
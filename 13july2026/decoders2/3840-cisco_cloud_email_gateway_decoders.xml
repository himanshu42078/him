<decoder name="cisco-cloud-email-gateway">
    <program_name>audit_logs</program_name>
    <prematch>^Info: Appliance: \S+, Interaction Mode:</prematch>
</decoder>

<decoder name="cisco-cloud-email-gateway-fields">
	<parent>cisco-cloud-email-gateway</parent>
	<regex>^(\S+): </regex>
	<order>severity</order>
</decoder>
<decoder name="cisco-cloud-email-gateway-fields">
	<parent>cisco-cloud-email-gateway</parent>
	<regex>Appliance: (\.+),</regex>
	<order>Appliance</order>
</decoder>
<decoder name="cisco-cloud-email-gateway-fields">
	<parent>cisco-cloud-email-gateway</parent>
	<regex>Interaction Mode: (\.+),</regex>
	<order>Interaction_Mode</order>
</decoder>
<decoder name="cisco-cloud-email-gateway-fields">
	<parent>cisco-cloud-email-gateway</parent>
	<regex>User: (\.+),</regex>
	<order>username</order>
</decoder>
<decoder name="cisco-cloud-email-gateway-fields">
	<parent>cisco-cloud-email-gateway</parent>
	<regex>User: (\.+),</regex>
	<order>dstuser</order>
</decoder>
<decoder name="cisco-cloud-email-gateway-fields">
	<parent>cisco-cloud-email-gateway</parent>
	<regex>Source IP: (\.+),</regex>
	<order>srcip</order>
</decoder>
<decoder name="cisco-cloud-email-gateway-fields">
	<parent>cisco-cloud-email-gateway</parent>
	<regex>Event: (\.+),|Event: (\.+)$</regex>
	<order>event</order>
</decoder>
<decoder name="cisco-cloud-email-gateway-fields">
	<parent>cisco-cloud-email-gateway</parent>
	<regex>Location: (\.+),</regex>
	<order>location</order>
</decoder>
<decoder name="cisco-cloud-email-gateway-fields">
	<parent>cisco-cloud-email-gateway</parent>
	<regex>Destination IP: (\.+),</regex>
	<order>dstip</order>
</decoder>
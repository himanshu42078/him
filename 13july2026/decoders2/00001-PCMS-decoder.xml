<!-- #######User Log Table start from here####### -->


<decoder name="PCMSUserLogTable">
	<prematch>"PCMS_USER_LOG": {</prematch>
</decoder>

<decoder name="PCMSUserLogTable-fields">
	<parent>PCMSUserLogTable</parent>
	<regex offset="after_parent">"UserLogStatus":\s"(\.*)",</regex>
	<order>UserLogStatus</order>
</decoder>

<decoder name="PCMSUserLogTable-fields">
	<parent>PCMSUserLogTable</parent>
    <regex offset="after_parent">"errorCode":\s(\.*),</regex>
    <order>errorCode</order>
</decoder>

<decoder name="PCMSUserLogTable-fields">
	<parent>PCMSUserLogTable</parent>
    <regex offset="after_parent">"eventTime":\s"(\.*)",</regex>
    <order>eventTime</order>
</decoder>

<decoder name="PCMSUserLogTable-fields">
	<parent>PCMSUserLogTable</parent>
    <regex offset="after_parent">"hostname":\s"(\.*)",</regex>
    <order>hostname</order>
</decoder>

<decoder name="PCMSUserLogTable-fields">
	<parent>PCMSUserLogTable</parent>
    <regex offset="after_parent">"seqNo":\s(\w+),</regex>
    <order>seqNo</order>
</decoder>

<decoder name="PCMSUserLogTable-fields">
	<parent>PCMSUserLogTable</parent>
    <regex offset="after_parent">"userID":\s"(\.*)"</regex>
    <order>userID</order>
</decoder>




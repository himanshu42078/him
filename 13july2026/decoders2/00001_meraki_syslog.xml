<decoder name="meraki_syslog">
	<prematch>1\s\d\d\d\d\d\d\d\d\d\d.\d\d\d\d\d\d\d\d\d\s</prematch>
</decoder>
<!-- Meraki MX Security Appliance
The priority score is based on Snort values. The priorities are as follows:
1 - high priority alert
2 - medium priority alert
3 - low priority alert
4 - very low priority alert
events	
vpn connectivity change	
1380664922.583851938 MX84 events type=vpn_connectivity_change vpn_type='site-to-site' peer_contact='98.68.191.209:51856' peer_ident='2814ee002c075181bb1b7478ee073860' connectivity='false'
1380664994.337961231 MX84 events type=vpn_connectivity_change vpn_type='site-to-site' peer_contact='98.68.191.209:51856' peer_ident='2814ee002c075181bb1b7478ee073860' connectivity='true'
-->
<decoder name="meraki_syslog_fields">
	<parent>meraki_syslog</parent>
	<regex offset="after_parent">(\S+)\s(events) type=(vpn_connectivity_change) vpn_type='(\S+)' peer_contact='(\S+):(\d+)' peer_ident='(\S+)' connectivity='(\S+)'</regex>
	<order>logsource, meraki.event, meraki.type, meraki.vpn_type, meraki.peer_contact_ip, meraki.peer_contact_port, meraki.peer_indent, meraki.connectivity</order>
</decoder>
<!--
  events
  vpn connectivity change	
  Dec 6 08:46:12 192.168.1.1 1 1386337584.254756845 MX84 events Cellular connection down
  Dec 6 08:45:24 192.168.1.1 1 1386337535.803931423 MX84 events failover to wan1
  Dec 6 08:43:43 192.168.1.1 1 1386337435.108107268 MX84 events failover to cellular
  Dec 6 08:41:44 192.168.1.1 1 1386337316.207232138 MX84 events Cellular connection up
-->
<decoder name="meraki_syslog_fields">
	<parent>meraki_syslog</parent>
	<regex offset="after_parent">(\S+) (events) (\S+)</regex>
	<order>logsource, meraki.event, msg</order>
</decoder>
<!-- Sep 11 16:12:41 192.168.10.1 1 1599865961.535491111 MX84 events dhcp no offers for mac A4:83:E7:XX:XX:XX host = 192.168.10.1 -->
<decoder name="meraki_syslog_fields">
	<parent>meraki_syslog</parent>
	<regex offset="after_parent">(\S+) (events) (dhcp no offers for mac) (\S+) host = (\S+)</regex>
	<order>logsource, meraki.event, msg, meraki.mac, srcip</order>
</decoder>
<!-- 1 1599865515.687171503 MX84 events dhcp lease of ip 192.168.10.68 from server mac E0:CB:BC:0F:XX:XX for client mac 8C:16:45:XX:XX:XX from router 192.168.10.1 on subnet 255.255.255.0 with dns 8.8.8.8, 8.8.4.4
wont do
-->
<!--
  1374543213.342705328 MX84 urls src=192.168.1.186:63735 dst=69.58.188.40:80 mac=58:1F:AA:CE:61:F2 request: GET https://...
-->
<decoder name="meraki_syslog_fields">
	<parent>meraki_syslog</parent>
	<regex offset="after_parent">(\S+) (urls) src=(\S+)\sdst=(\S+)\smac=(\S+)\srequest: (\S+) (\S+)</regex>
	<order>logsource, meraki.event, srcip, dstip, meraki.mac, meraki.request_type, url</order>
</decoder>
<!-- 1374543986.038687615 MX84 flows src=192.168.1.186 dst=8.8.8.8 mac=58:1F:AA:CE:61:F2 protocol=udp sport=55719 dport=53 pattern: allow all -->
<decoder name="meraki_syslog_fields">
	<parent>meraki_syslog</parent>
	<regex offset="after_parent">(\S+) (flows) src=(\S+)\sdst=(\S+)\smac=(\S+)\sprotocol=(\S+)\ssport=(\S+)\sdport=(\S+)\s pattern: (\.+)</regex>
	<order>logsource, meraki.event, srcip, dstip, meraki.mac, protocol, srcport,dstport,meraki.pattern</order>
</decoder>
<!-- 1377449842.514782056 MX84 ids-alerts signature=129:4:1 priority=3 timestamp=1377449842.512569 direction=ingress protocol=tcp/ip src=74.125.140.132:80-->
<decoder name="meraki_syslog_fields">
	<parent>meraki_syslog</parent>
	<regex offset="after_parent">(\S+) (ids-alerts) signature=(\S+)\spriority=(\d+)\stimestamp=(\S+)\sdirection=(\S+)\sprotocol=(\S+)\ssrc=(\S+):(\d+)</regex>
	<order>logsource, meraki.event, meraki.signature, meraki.priority, meraki.timestamp, meraki.direction, protocol,srcip,srcport</order>
</decoder>
<!-- 1377449842.514782056 MX84 ids-alerts signature=1:28423:1 priority=1 timestamp=1468531589.810079
dhost=98:5A:EB:E1:81:2F direction=ingress protocol=tcp/ip src=151.101.52.238:80
dst=192.168.128.2:53023 message: EXPLOIT-KIT Multiple exploit kit single digit
exe detection -->
<decoder name="meraki_syslog_fields">
	<parent>meraki_syslog</parent>
	<regex offset="after_parent">(\S+) (ids-alerts) signature=(\S+)\spriority=(\d+)\stimestamp=(\S+)\sdirection=(\S+)\sprotocol=(\S+)\ssrc=(\S+):(\d+)\sdst=(\S+):(\d+)\smessage: (\.+)</regex>
	<order>logsource, meraki.event, meraki.signature, meraki.priority, meraki.timestamp, meraki.direction, protocol,srcip,srcport,dstip, dstport, msg</order>
</decoder>
<!-- url=http://www.eicar.org/download/eicar.com.txt src=192.168.128.2:53150 dst=188.40.238.250:80 mac=98:5A:EB:E1:81:2F name='EICAR:EICAR_Test_file_not_a_virus-tpd' sha256=275a021bbfb6489e54d471899f7db9d1663fc695ec2fe2a2c4538aabf651fd0f disposition=malicious action=block -->
<decoder name="meraki_syslog_fields">
	<parent>meraki_syslog</parent>
	<regex offset="after_parent">url=(\S+)\ssrc=(\S+)\sdst=(\S+)\smac=(\S+)\sname=(\S+)\ssha256=(\S+)\sdisposition=(\S+)\saction=(\S+)</regex>
	<order>url, srcip,dstip, meraki.mac, meraki.name, meraki.sha256, meraki.disposition, meraki.action</order>
</decoder>
<decoder name="meraki_syslog_fields">
	<parent>meraki_syslog</parent>
	<regex offset="after_parent">name=(\S+)\ssha256=(\S+)\sdisposition=(\S+)\saction=(\S+)</regex>
	<order>meraki.name, meraki.sha256, meraki.disposition, meraki.action</order>
</decoder>

<decoder name="aruba_networks-syslog">
  <!-- program_name>
^aruba_networks</program_name -->
  <prematch> LEEF:1.0\|Aruba Networks\|</prematch>
</decoder>
<decoder name="aruba_networks-syslog-fields">
  <parent>aruba_networks-syslog</parent>
  <regex>LEEF:1.0\|Aruba Networks\|(\.*)\|\.*\|\.*\|</regex>
  <order>event_product</order>
</decoder>
<!--Common Fields-->

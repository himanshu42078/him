<!-- DEV-683 -->

<decoder name="Twistlock">
	<program_name>^Twistlock-Console|^Twistlock-Defender</program_name>
</decoder>
<!-- Twistlock-Console -->
<decoder name="Twistlock-Console">
	<parent>Twistlock</parent>

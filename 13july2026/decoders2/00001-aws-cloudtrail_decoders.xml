</decoder>
<decoder name="aws-cloudtrail-fields">
	<parent>aws-cloudtrail</parent>
	<regex>"sourceIPAddress":\s*"(\d+.\d+.\d+.\d+)"</regex>
	<order>srcip</order>
</decoder>
<decoder name="aws-cloudtrail-fields">
	<parent>aws-cloudtrail</parent>
	<regex>"source_ip_address":\s*"(\d+.\d+.\d+.\d+)"</regex>
	<order>srcip</order>
</decoder>
<decoder name="aws-cloudtrail-fields">

<!-- aws Decoder The purpose of this decoder is to obtain standardized field-->
<decoder name="aws-cloudtrail">
	<prematch>{"integration": "aws", "aws":\.+"source": "cloudtrail"</prematch>
</decoder>
<decoder name="aws-cloudtrail-fields">
	<parent>aws-cloudtrail</parent>
	<regex>"integration": "(\.+)"</regex>
	<order>integration</order>
</decoder>
<decoder name="aws-cloudtrail-fields">
	<parent>aws-cloudtrail</parent>
	<regex>"source": "(\.+)"</regex>
	<order>aws.source</order>
</decoder>
<decoder name="aws-cloudtrail-fields">
	<parent>aws-cloudtrail</parent>
	<regex>"awsRegion": "(\.+)"</regex>
	<order>aws.awsRegion</order>
</decoder>
<decoder name="aws-cloudtrail-fields">
	<parent>aws-cloudtrail</parent>
	<regex>"eventName": "(\.+)"</regex>

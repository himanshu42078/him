<decoder name="PostgreSQL">
	<prematch>^\d+-\d+-\d+ \d+:\d+:\d+.\d* \S+,"\S+","\S+",\d+,"\S+",\S+,\d+,"\S+",\d+-\d+-\d+ \d+:\d+:\d+ \S+,\S+,\d+,\S+,\S+,</prematch>
</decoder>

<decoder name="PostgreSQL-fields">
	<parent>PostgreSQL</parent>
	<regex>\d+-\d+-\d+ \d+:\d+:\d+.\d* \S+,"\S+","\S+",\d+,"(\d+.\d+.\d+.\d+):(\d+)",\S+,\d+,"\S+",\d+-\d+-\d+ \d+:\d+:\d+ \S+,\S+,\d+,\S+,\S+,"(\.+)"</regex>
	<order>srcip,srcport,msg</order>
</decoder>
<decoder name="PostgreSQL-fields">
	<parent>PostgreSQL</parent>
	<regex>password authentication failed for user ""(\.+)""</regex>
	<order>dstuser</order>
</decoder>
<decoder name="PostgreSQL-fields">
	<parent>PostgreSQL</parent>
	<regex>connection authorized: user=(\S+) database=(\S+)</regex>
	<order>dstuser,database</order>
</decoder>
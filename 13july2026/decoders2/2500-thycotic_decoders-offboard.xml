<decoder name="thycotic">
	<prematch>\|Thycotic Software\|</prematch>
	<program_name>CEF</program_name>
</decoder>
<decoder name="thycotic_secret_server_fields">
	<parent>thycotic</parent>
	<regex>\d+\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|</regex>
	<order>vendor, product, version, eventId, description, severity</order>
</decoder>
<decoder name="thycotic_secret_server_fields">
	<parent>thycotic</parent>
	<regex>msg=(\.+) \S+=</regex>
	<order>thycotic.msg</order>
</decoder>

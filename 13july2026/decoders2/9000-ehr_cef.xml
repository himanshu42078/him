
<decoder name="ehr_cef">
    <program_name>CEF</program_name>
    <prematch>^0\|eHR\|</prematch>
</decoder>

<decoder name="ehr_cef">
    <program_name></program_name>
	<prematch>CEF:\s*0\|eHR\|\.+\|\.+\|\.+\|\.+\|\.+\|</prematch>
</decoder>

<decoder name="ehr_cef">
	<prematch>CEF:\s*0\|eHR\|\.+\|\.+\|\.+\|\.+\|\.+\|</prematch>
</decoder>

<decoder name="ehr_cef_fields">
    <parent>ehr_cef</parent>
    <regex>\d+\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|</regex>
    <order>cef.vendor, cef.product, cef.version, cef.event_class_id, cef.description, cef.severity</order>
</decoder>

<decoder name="ehr_cef_fields">
    <parent>ehr_cef</parent>
    <regex>Date=(\.+) \S+=</regex>
    <order>cef.extensions.Date</order>
</decoder>

<decoder name="ehr_cef_fields">
    <parent>ehr_cef</parent>
    <regex>LENGTH=(\.+) \S+=</regex>
    <order>cef.extensions.LENGTH</order>
</decoder>

<decoder name="ehr_cef_fields">

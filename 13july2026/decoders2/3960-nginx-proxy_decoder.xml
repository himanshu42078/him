<decoder name="nginx_proxy">
    <program_name>nginx_proxy01</program_name>
    <prematch>^\d+.\d+.\d+.\d+\s+forwarded for \S+ \S+ \S+ \p\S+/\S+/\S+:\d\d:\d\d:\d\d \S+\p</prematch>
</decoder>
<decoder name="nginx_proxy-fields">
    <parent>nginx_proxy</parent>
    <regex>^(\d+.\d+.\d+.\d+)\s+forwarded for \S+ \S+ \S+ \p\S+/\S+/\S+:\d\d:\d\d:\d\d \S+\p\s+"(\S+) \S+ \S+" (\S+) \S+ "(\.*)" "(\.*)"</regex>

<decoder name="conjur">
        <prematch>\p\d+\p\d+ \d+-\d+-\d+T\d+:\d+:\d+.\d++\d+:\d+ \S+ conjur</prematch>
</decoder>

<decoder name="conjur-custom">
        <parent>conjur</parent>
        <regex>\p(\d+)\p(\d+) (\d+-\d+-\d+T\d+:\d+:\d+.\d++\d+:\d+) (\S+) conjur (\S+) (\S+)</regex>
        <order>conjur.priorityVal,conjur.version,conjur.timestamp,conjur.hostname,conjur.processId,conjur.messageId</order>
</decoder>

<!-- begin of conjur-conjur-structure -->

<!-- subject -->
<decoder name="conjur-custom">
   <parent>conjur</parent>
   <regex>[subject@\d+ role="(\.+)"]</regex>
   <order>conjur.subject.role</order>
</decoder>

<decoder name="conjur-custom">
   <parent>conjur</parent>
   <regex>[subject@\d+ resource="(\.+)"]</regex>
   <order>conjur.subject.resource</order>
</decoder>

<decoder name="conjur-custom">
   <parent>conjur</parent>
   <regex>[subject@\d+ resource="(\.+)" role="(\.+)" privilege="(\.+)"]</regex>
   <order>conjur.subject.resource,conjur.subject.role,conjur.subject.privilege</order>
</decoder>

<!-- auth -->
<decoder name="conjur-custom">
   <parent>conjur</parent>
   <regex>[auth@\d+ user="(\.+)"]</regex>
   <order>conjur.auth.user</order>
</decoder>

<decoder name="conjur-custom">
   <parent>conjur</parent>
   <regex>[auth@\d+ authenticator="(\.+)" service="(\.+)" user="(\.+)"]</regex>
   <order>conjur.auth.authenticator,conjur.auth.service,conjur.auth.user</order>
</decoder>

<!-- client -->
<decoder name="conjur-custom">
   <parent>conjur</parent>
   <regex>[client@\d+ ip="(\.+)"]</regex>
   <order>srcip</order>
</decoder>

<!-- action -->
<decoder name="conjur-custom">
   <parent>conjur</parent>
   <regex>[action@\d+ result="(\.+)" operation="(\.+)"]</regex>
   <order>conjur.action.result,conjur.action.operation</order>
</decoder>

<!-- meta -->
<decoder name="conjur-custom">
   <parent>conjur</parent>
   <regex>[meta sequenceId="(\.+)"]</regex>
   <order>conjur.meta.sequenceId</order>
</decoder>

<!-- end of conjur-conjur-structure -->
<decoder name="conjur-custom">
        <parent>conjur</parent>
        <regex>] (\S+:\S+:\.+)</regex>
        <order>conjur.message</order>
</decoder>



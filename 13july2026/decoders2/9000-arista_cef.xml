<decoder name="arista_cef">
    <program_name>CEF</program_name>
    <prematch>^0\|Arista Networks\|</prematch>
</decoder>

<decoder name="arista_cef">
    <program_name></program_name>
	<prematch>CEF:\s*0\|Arista Networks\|\.+\|\.+\|\.+\|\.+\|\.+\|</prematch>
</decoder>

<decoder name="arista_cef">
	<prematch>CEF:\s*0\|Arista Networks\|\.+\|\.+\|\.+\|\.+\|\.+\|</prematch>
</decoder>

<decoder name="arista_cef_fields">
    <parent>arista_cef</parent>
    <regex>\d+\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|</regex>
    <order>cef.vendor, cef.product, cef.version, cef.event_class_id, cef.description, cef.severity</order>
</decoder>

<decoder name="arista_cef_fields">

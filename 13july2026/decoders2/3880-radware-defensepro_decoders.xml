<decoder name="radware-defensepro">
    <prematch>^[Device: \S+ \S+] M_20000: \S+ attack\S* of type</prematch>
</decoder>
<decoder name="radware-defensepro-fields">
    <parent>radware-defensepro</parent>
    <regex>^[Device: \S+ \S+] M_20000: (\.+). Detected by policy: (\S+);</regex>
    <order>msg,policy</order>
</decoder>
<decoder name="radware-defensepro-fields">
    <parent>radware-defensepro</parent>
    <regex>Attack name: (\.+);|Attack names: (\.+);</regex>
    <order>attack_name</order>
</decoder>
<decoder name="radware-defensepro-fields">
    <parent>radware-defensepro</parent>
    <regex>Source IP: (\d+.\d+.\d+.\d+);|Source IPs: (\d+.\d+.\d+.\d+),</regex>
    <order>srcip</order>
</decoder>
<decoder name="radware-defensepro-fields">
    <parent>radware-defensepro</parent>
    <regex>Destination IP: (\d+.\d+.\d+.\d+);|Destination IPs: (\d+.\d+.\d+.\d+),</regex>
    <order>dstip</order>
</decoder>
<decoder name="radware-defensepro-fields">
    <parent>radware-defensepro</parent>
    <regex>Destination port: (\S+);|Destination ports: (\S+),</regex>
    <order>dstport</order>
</decoder>
<decoder name="radware-defensepro-fields">
    <parent>radware-defensepro</parent>
    <regex>Action\S*: (\.+).</regex>
    <order>action</order>
</decoder>
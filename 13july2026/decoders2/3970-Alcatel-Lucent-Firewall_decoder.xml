<!-- DEV-4973 -->
<decoder name="Alcatel-Lucent-Firewall">
    <prematch>\p\d+\p\S+\s+\d+ \d\d:\d\d:\d\d \S+ \S+: SerialNum=\S+ GenTime=</prematch>
</decoder>
<decoder name="Alcatel-Lucent-Firewall-fields">
    <parent>Alcatel-Lucent-Firewall</parent>
    <regex>(\S+): SerialNum=</regex>
    <order>type</order>
</decoder>

<!-- Sas_system comb03 Decoder -->
<decoder name="sas_system">
  <prematch>New\sclient\sconnection\s\(\d+\)\s\w+\sfrom\sserver\sport\s\d+\sfor\sSAS\stoken\suser</prematch>
</decoder>

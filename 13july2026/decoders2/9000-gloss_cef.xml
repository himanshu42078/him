<decoder name="gloss_cef">
    <program_name>CEF</program_name>
    <prematch>^0\|Gloss\|</prematch>
</decoder>

<decoder name="gloss_cef">
    <program_name></program_name>
	<prematch>CEF:\s*0\|Gloss\|\.+\|\.+\|\.+\|\.+\|\.+\|</prematch>
</decoder>

<decoder name="gloss_cef">
	<prematch>CEF:\s*0\|Gloss\|\.+\|\.+\|\.+\|\.+\|\.+\|</prematch>
</decoder>

<decoder name="gloss_cef_fields">
    <parent>gloss_cef</parent>
    <regex>\d+\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|</regex>
    <order>cef.vendor, cef.product, cef.version, cef.event_class_id, cef.description, cef.severity</order>
</decoder>

<decoder name="gloss_cef_fields">
    <parent>gloss_cef</parent>
    <regex>Partition=(\.+) \S+=</regex>
    <order>cef.extensions.Partition</order>
</decoder>

<decoder name="gloss_cef_fields">

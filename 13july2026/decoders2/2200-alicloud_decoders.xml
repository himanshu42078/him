<decoder name="alicloud">
	<prematch>^\d \d+-\d+-\d+T\d+:\d+:\d+.\d+\S+</prematch>
</decoder>
<decoder name="alicloud-fields">
	<parent>alicloud</parent>
	<regex>\d (\d+-\d+-\d+T\d+:\d+:\d+.\d+\S+) (\S+) (\S+)</regex>
	<order>timestamp,logsource,region</order>
</decoder>
<decoder name="alicloud-fields">
	<parent>alicloud</parent>
	<regex>status=(\.+)\|status=(\.+)</regex>
	<order>status</order>
</decoder>
<decoder name="alicloud-fields">

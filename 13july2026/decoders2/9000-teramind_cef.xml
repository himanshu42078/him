<decoder name="teramind_cef">
    <program_name>CEF</program_name>
    <prematch>^0\|Teramind\|</prematch>
</decoder>

<decoder name="teramind_cef">
    <program_name></program_name>
	<prematch>CEF:\s*0\|Teramind\|\.+\|\.+\|\.+\|\.+\|\.+\|</prematch>
</decoder>

<decoder name="teramind_cef">
	<prematch>CEF:\s*0\|Teramind\|\.+\|\.+\|\.+\|\.+\|\.+\|</prematch>
</decoder>

<decoder name="teramind_cef_fields">
    <parent>teramind_cef</parent>
    <regex>\d+\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|</regex>
    <order>cef.vendor, cef.product, cef.version, cef.event_class_id, cef.description, cef.severity</order>
</decoder>

<decoder name="teramind_cef_fields">
    <parent>teramind_cef</parent>
    <regex>act=(\.+) \S+=</regex>
    <order>cef.extensions.act</order>
</decoder>

<decoder name="teramind_cef_fields">

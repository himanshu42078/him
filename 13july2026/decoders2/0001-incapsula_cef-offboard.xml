<decoder name="incapsula_cef">
	<program_name>CEF</program_name>
	<prematch>Incapsula\|SIEMintegration</prematch>
</decoder>
<decoder name="incapsula_fields">
	<parent>incapsula_cef</parent>
	<regex>SIEMintegration\|\.+\|(\.+)\|(\.+)\|(\d+)</regex>
	<order>configID, alertSeverity, internalRuleID</order>
</decoder>
<decoder name="incapsula_fields">
	<parent>incapsula_cef</parent>
	<regex>\d+\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|(\.+)\|</regex>
	<order>vendor, product, version, eventId, description, severity</order>
</decoder>

[UserAudit:LOGGED_IN_USERNAME:IPADDRESS] [OPERATION_TYPE] [OPERATED_TIME] [STATUS_OF_OPERATION] [PMP_SERVER_NAME] [ORG_NAME-LOGGED_IN_USERNAME:REASON]
-->
<decoder name="pmp">
	<program_name>UserAudit</program_name>
</decoder>

<decoder name="pmp_fields">
  <parent>pmp</parent>
  <regex>\S*:(\S*) (\S*) (\d\d\d\d/\d\d/\d\d \d\d:\d\d:\d\d) (\S*) (\S*) -(\S*):(\S*)</regex>
  <order>pmp.ipaddress, action, pmp.timestamp, pmp.status_of_operation, pmp.server_name, srcuser, pmp.reason</order>
</decoder>
<decoder name="pmp_fields">
  <parent>pmp</parent>
  <regex>\S*:\S* \S* \d\d\d\d/\d\d/\d\d \d\d:\d\d:\d\d \S* \S* -(\S*):\S*</regex>
  <order>username</order>
</decoder>
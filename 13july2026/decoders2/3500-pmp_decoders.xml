[ResourceAudit:LOGGED_IN_USERNAME:IPADDRESS] [OPERATION_TYPE] [OPERATED_TIME] [STATUS_OF_OPERATION] [PMP_SERVER_NAME] [ORG_NAME-RESOURCE_NAME:ACCOUNT_NAME:REASON]
-->
<decoder name="pmp">
	<program_name>ResourceAudit</program_name>
</decoder>

<decoder name="pmp_fields">
  <parent>pmp</parent>
  <regex>(\S*):(\S*) (\S*) (\d\d\d\d/\d\d/\d\d \d\d:\d\d:\d\d) (\S*) (\S*) (\S*):(\S*):\S*:(\S*)</regex>
  <order>srcuser, pmp.ipaddress, action, pmp.timestamp, pmp.status_of_operation, pmp.server_name, pmp.resource_name, dstuser, pmp.reason</order>
</decoder>


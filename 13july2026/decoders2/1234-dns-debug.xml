<!-- DNS-Debug Decoder -->
<decoder name="dns-debug">
  <prematch>\s\S\S\S\S\sPACKET\s+\w\w\w\w\w\w\w\w\w\w\w\w\w\w\w\w\s</prematch>
</decoder>
<decoder name="dns-debug-fields">
  <parent>dns-debug</parent>
  <regex>(\w\w\w)\s+(\w\w\w)\s+(\d*.\d*.\d*.\d*)\s+\S\S\S\S\s+(R)\s+(Q)\s+[(\d\d\d\d)\s+\w+\s+(\w+)]\s+(\w+)\s+(\S*)$</regex>
  <order>protocol,dns.direction,srcip,dns.response,dns.request,dns.flag,dns.rcode,dns.rrtype,dns.domain</order>
</decoder>
<decoder name="dns-debug-fields">
  <parent>dns-debug</parent>
  <regex>(\w\w\w)\s+(\w\w\w)\s+(\d*.\d*.\d*.\d*)\s+\S\S\S\S\s+(Q)\s+[(\d\d\d\d)\s+\w+\s+(\w+)]\s+(\w+)\s+(\S*)$</regex>
  <order>protocol,dns.direction,srcip,dns.request,dns.flag,dns.rcode,dns.rrtype,dns.domain</order>
</decoder>

<!-- DEV-642 -->
<!-- General CarbonBlack Decoder -->

<decoder name="CarbonBlack">
	<prematch>Carbon Black\|\.+\|\S+\|\d+\|\.+\|\d+\|</prematch>
	<program_name>CEF</program_name>
</decoder>

<!-- VMWare Carbon Black EDR 7.7.1 -->
<!--
Reference:
https://docs.vmware.com/en/VMware-Carbon-Black-EDR/7.7.1/cb-edr-integration-guide/GUID-1590E6D0-6F9E-4917-8C53-12A377E60141.html 
-->
<decoder name="CarbonBlack">
	<prematch>CEF:0\|Carbon Black\|\.+\|\S+\|reason=\S+\|\.+\|\d+\|</prematch>
</decoder>

<decoder name="CarbonBlack-field">
	<parent>CarbonBlack</parent>
	<regex>0\|(\.+)\|(\.+)\|(\S+)\|reason=(\S+)\|(\.+)\|(\d+)\|</regex>
	<order>vendor, product, version, eventId, description, severity</order>
</decoder>

<decoder name="CarbonBlack-field">
	<parent>CarbonBlack</parent>
	<regex>0\|(\.+)\|(\.+)\|(\S+)\|(\S+)\|(\.+)\|(\d+)\|</regex>
	<order>vendor, product, version, eventId, description, severity</order>
</decoder>

<decoder name="CarbonBlack-field">
	<parent>CarbonBlack</parent>
	<regex>externalId=(\S+)</regex>
	<order>cb.externalId</order>
</decoder>

<decoder name="CarbonBlack-field">
	<parent>CarbonBlack</parent>
	<regex>cat=(\.+) start=</regex>
	<order>cb.cat</order>
</decoder>

<decoder name="CarbonBlack-field">
	<parent>CarbonBlack</parent>
	<regex>start=(\S+ \d+ \d+:\d+:d+) UTC</regex>
	<order>cb.start</order>
</decoder>

<decoder name="CarbonBlack-field">
	<parent>CarbonBlack</parent>
	<regex>start=(\.+) UTC</regex>
	<order>cb.start</order>
</decoder>

<decoder name="CarbonBlack-field">
	<parent>CarbonBlack</parent>
	<regex>rt=(\S+ \d+ \d+:\d+:d+) UTC</regex>
	<order>cb.rt</order>
</decoder>

<decoder name="CarbonBlack-field">
	<parent>CarbonBlack</parent>
	<regex>start=(\.+) UTC</regex>
	<order>cb.rt</order>
</decoder>

<decoder name="CarbonBlack-field">
	<parent>CarbonBlack</parent>
	<regex>start=(\.+) \S+=</regex>
	<order>cb.rt</order>
</decoder>


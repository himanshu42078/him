<decoder name="juniper_traffic_event">
        <program_name>kmd</program_name>
</decoder>
<decoder name="juniper_traffic_event_fields">
    <parent>juniper_traffic_event</parent>
    <regex type="pcre2">([^:]+):\.*</regex>
    <order>action</order>
</decoder>
<decoder name="juniper_traffic_event_fields">
    <parent>juniper_traffic_event</parent>
    <regex type="pcre2">Local gateway: (\S+),</regex>
    <order>local_gateway</order>
</decoder>

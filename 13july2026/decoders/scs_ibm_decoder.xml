<decoder name="cef-header-frame">
  <program_name>CEF</program_name>
</decoder>

<decoder name="cef-razlee-fields">
  <parent>cef-header-frame</parent>
  <regex type="pcre2">\s*(\d+)\|(\w+)\|(\w+)\|(\S+)\|(\w+)\|([^|]+)\|(\d+)\|</regex>
  <order>cef_version,vendor,product_name,product_version,event_id,event_name,severity</order>
</decoder>

<decoder name="cef-razlee-fields">
  <parent>cef-header-frame</parent>
  <regex>suser=(\S+)</regex>
  <order>src_user</order>
</decoder>

<decoder name="cef-razlee-fields">
  <parent>cef-header-frame</parent>
  <regex>outcome=(\S+)</regex>
  <order>outcome</order>
</decoder>

<decoder name="cef-razlee-fields">
  <parent>cef-header-frame</parent>
  <regex>duser=(\S+)</regex>
  <order>dst_user</order>
</decoder>

<decoder name="cef-razlee-fields">
  <parent>cef-header-frame</parent>
  <regex>src=(\S+)</regex>
  <order>src_ip</order>
</decoder>

<decoder name="cef-razlee-fields">
  <parent>cef-header-frame</parent>
  <regex>sproc=(\S+)</regex>
  <order>source_process</order>
</decoder>

<decoder name="cef-razlee-fields">
  <parent>cef-header-frame</parent>
  <regex>PGM=(\S+)</regex>
  <order>ibm_program</order>
</decoder>

<decoder name="cef-razlee-fields">
  <parent>cef-header-frame</parent>
  <regex type="pcre2">reason=(\w+/\w+)</regex>
  <order>reason</order>
</decoder>


